---
import BaseLayout from "../layouts/BaseLayout.astro";
import GlossaryGrid from "../../components/GlossaryGrid.astro";
import { getAllTerms } from "../../lib/termSearch";

const terms = getAllTerms();
---

<BaseLayout
  title="Glossary — CineCards AI"
  description="124 film and AI video terms — shots, angles, lighting, movement, editing, and prompting — as searchable, copyable cards."
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="container-pad">
      <span class="page-eyebrow">124 Terms · 8 Categories · AI-Ready</span>
      <h1 class="page-h1">Film Language, Explained.</h1>
      <p class="page-subtitle">Every term teaches you what it is, why it matters, how to shoot it, and how to prompt it in AI video tools.</p>
    </div>
  </section>

  <!-- Grid -->
  <section class="page-section page-section-sand">
    <div class="container-pad">
      <GlossaryGrid terms={terms} />
    </div>
  </section>
</BaseLayout>
