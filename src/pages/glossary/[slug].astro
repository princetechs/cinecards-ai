---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PreviewCard from "../../../components/PreviewCard.astro";
import { getAllTerms, getTermByName } from "../../../lib/termSearch";
import { loadProvenance, summariseRights } from "../../../lib/provenance";
import type { Term } from "../../../types/term";

export async function getStaticPaths() {
  return getAllTerms().map((term) => ({
    params: { slug: term.id },
    props: { term }
  }));
}

interface Props {
  term: Term;
  // tolerate optional prerequisites if/when added to the data
  // (the field may not exist on all terms)
}

const { term } = Astro.props as Props & { term: Term & { prerequisites?: string[] } };

const related = term.relatedTerms
  .map((name) => ({ name, match: getTermByName(name) }))
  .filter((r) => r.name);

const prerequisites = Array.isArray((term as any).prerequisites)
  ? ((term as any).prerequisites as string[])
      .map((name) => ({ name, match: getTermByName(name) }))
  : [];

const reviewStatus = term.review?.status ?? "approved";
const isApproved = reviewStatus === "approved";

const assetRows = isApproved && Array.isArray(term.assets)
  ? term.assets.map((asset) => {
      const r = (asset.rights ?? {}) as Record<string, unknown>;
      const licence = typeof r.licence === "string" ? r.licence : "unspecified licence";
      return { type: asset.type, url: asset.url, licence };
    })
  : [];

const provenanceRecords = await loadProvenance(term.id);
const provenanceRights = provenanceRecords[0]
  ? summariseRights(provenanceRecords[0].provider)
  : null;

const pageTitle = `${term.name} - aiscreens Glossary`;
const pageDescription = term.shortDefinition;
const canonical = new URL(`/glossary/${term.id}`, Astro.site ?? Astro.url).href;
const ogImage = new URL("/images/aiscreens-hero.png", Astro.site ?? Astro.url).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  name: term.name,
  description: term.shortDefinition,
  inDefinedTermSet: {
    "@type": "DefinedTermSet",
    name: "aiscreens Glossary",
    url: new URL("/glossary", Astro.site ?? Astro.url).href
  },
  termCode: term.id,
  url: canonical,
  about: term.category,
  keywords: term.tags.join(", ")
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <section class="bg-paper py-10">
    <div class="container-pad">
      <nav class="text-xs font-bold uppercase tracking-wide text-ink/55">
        <a class="hover:text-ink" href="/glossary">Glossary</a>
        <span class="px-2 text-ink/30">/</span>
        <span class="text-ink/70">{term.category}</span>
      </nav>
      <div class="mt-4 flex flex-wrap items-center gap-2">
        <span class="rounded-full bg-ink px-3 py-1 text-xs font-black text-bone">{term.category}</span>
        <span class="rounded-full bg-bone px-3 py-1 text-xs font-bold text-ink/62">{term.priorityGroup}</span>
        <span class="rounded-full border border-ink/10 px-3 py-1 text-xs font-bold text-ink/58">{term.difficulty}</span>
      </div>
      <h1 class="mt-4 text-4xl font-black tracking-tight text-ink sm:text-5xl">{term.name}</h1>
      <p class="mt-4 max-w-3xl text-lg leading-7 text-ink/72">{term.shortDefinition}</p>
    </div>
  </section>

  <section class="py-12">
    <div class="container-pad grid gap-6 lg:grid-cols-3">
      <div class="space-y-6 lg:col-span-2">
        <article class="rounded-lg border border-ink/10 bg-bone p-6 shadow-soft">
          <h2 class="text-xs font-black uppercase tracking-wide text-clay">Why it matters</h2>
          <p class="mt-2 text-base leading-7 text-ink/74">{term.whyItMatters}</p>
        </article>

        <article class="rounded-lg border border-ink/10 bg-bone p-6 shadow-soft">
          <h2 class="text-xs font-black uppercase tracking-wide text-clay">When to use</h2>
          <ul class="mt-2 flex flex-wrap gap-2">
            {term.whenToUse.map((use) => (
              <li class="rounded-full bg-paper px-3 py-1 text-xs font-bold text-ink/64">{use}</li>
            ))}
          </ul>
        </article>

        <article class="rounded-lg border border-ink/10 bg-bone p-6 shadow-soft">
          <h2 class="text-xs font-black uppercase tracking-wide text-clay">Human shoot hint</h2>
          <p class="mt-2 text-base leading-7 text-ink/74">{term.humanShootHint}</p>
        </article>

        <article class="rounded-lg border border-ink/10 bg-bone p-6 shadow-soft">
          <div class="flex items-center justify-between gap-3">
            <h2 class="text-xs font-black uppercase tracking-wide text-clay">AI prompt template</h2>
            <button class="focus-ring rounded-lg border border-ink/12 px-3 py-1.5 text-xs font-bold text-ink/70 hover:bg-ink hover:text-bone" type="button" data-copy-prompt={term.aiPromptTemplate}>Copy</button>
          </div>
          <p class="mt-3 break-words rounded-lg bg-ink p-4 font-mono text-sm leading-6 text-bone">{term.aiPromptTemplate}</p>
        </article>

        <article class="rounded-lg border border-ink/10 bg-bone p-6 shadow-soft">
          <h2 class="text-xs font-black uppercase tracking-wide text-clay">Preview prompts</h2>
          <div class="mt-3">
            <PreviewCard term={term} />
          </div>
        </article>

        <article class="rounded-lg border border-ink/10 bg-bone p-6 shadow-soft">
          <h2 class="text-xs font-black uppercase tracking-wide text-clay">Common mistakes</h2>
          <ul class="mt-3 space-y-2 text-ink/72">
            {term.commonMistakes.map((mistake) => (
              <li class="flex gap-2"><span class="text-clay" aria-hidden="true">-</span><span>{mistake}</span></li>
            ))}
          </ul>
        </article>

        {!isApproved && (
          <article class="rounded-lg border border-ink/10 bg-bone/60 p-4 text-sm text-ink/55 shadow-soft">
            This card is under review.
          </article>
        )}

        {isApproved && assetRows.length > 0 && (
          <article class="rounded-lg border border-ink/10 bg-bone p-6 shadow-soft">
            <h2 class="text-xs font-black uppercase tracking-wide text-clay">Assets</h2>
            <ul class="mt-3 space-y-2 text-sm">
              {assetRows.map((asset) => (
                <li class="flex flex-wrap items-center gap-2">
                  <span class="rounded-full bg-paper px-2 py-0.5 text-xs font-bold text-ink/64">{asset.type}</span>
                  <a class="break-all font-mono text-xs text-ink underline hover:text-clay" href={asset.url} target="_blank" rel="noreferrer">{asset.url}</a>
                  <span class="rounded-full border border-ink/10 px-2 py-0.5 text-xs font-bold text-ink/58">{asset.licence}</span>
                </li>
              ))}
            </ul>
          </article>
        )}

        {provenanceRecords.length > 0 && (
          <article class="rounded-lg border border-ink/10 bg-bone p-6 shadow-soft">
            <details>
              <summary class="cursor-pointer list-none text-xs font-black uppercase tracking-wide text-clay">
                <span aria-hidden="true">&#9432;</span> Provenance
                <span class="ml-2 rounded-full bg-paper px-2 py-0.5 text-[10px] font-bold text-ink/64">{provenanceRecords.length} record{provenanceRecords.length === 1 ? "" : "s"}</span>
              </summary>
              <div class="mt-4 overflow-x-auto">
                <table class="min-w-full text-left text-sm">
                  <thead>
                    <tr class="border-b border-ink/10 text-xs font-bold uppercase tracking-wide text-ink/55">
                      <th class="py-2 pr-4">Provider</th>
                      <th class="py-2 pr-4">Model</th>
                      <th class="py-2 pr-4">Prompt hash</th>
                      <th class="py-2 pr-4">Rendered</th>
                      <th class="py-2 pr-4">C2PA</th>
                    </tr>
                  </thead>
                  <tbody>
                    {provenanceRecords.map((record) => (
                      <tr class="border-b border-ink/5 align-top">
                        <td class="py-2 pr-4 font-bold text-ink">{record.provider}</td>
                        <td class="py-2 pr-4 text-ink/72">{record.modelVersion ?? "—"}</td>
                        <td class="py-2 pr-4 font-mono text-xs text-ink/72" title={record.promptHash}>{record.promptHash.slice(0, 12)}…</td>
                        <td class="py-2 pr-4 text-ink/72">{record.renderDate}</td>
                        <td class="py-2 pr-4 text-ink/72">{record.c2pa ? <span class="rounded-full bg-paper px-2 py-0.5 text-xs font-bold text-ink/64" title={record.c2pa}>signed</span> : "—"}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              {provenanceRights && (
                <dl class="mt-4 grid gap-3 text-sm text-ink/74 sm:grid-cols-2">
                  <div>
                    <dt class="text-xs font-bold uppercase tracking-wide text-ink/55">Provider usage rights</dt>
                    <dd class="mt-1">{provenanceRights.providerOwnership}</dd>
                  </div>
                  <div>
                    <dt class="text-xs font-bold uppercase tracking-wide text-ink/55">Likely copyright status</dt>
                    <dd class="mt-1">{provenanceRights.copyrightStatus}</dd>
                  </div>
                </dl>
              )}
            </details>
          </article>
        )}

        {term.rights && (
          <article class="rounded-lg border border-ink/10 bg-bone p-6 shadow-soft">
            <h2 class="text-xs font-black uppercase tracking-wide text-clay">Rights &amp; attribution</h2>
            <dl class="mt-3 grid gap-2 text-sm text-ink/74 sm:grid-cols-3">
              <div>
                <dt class="text-xs font-bold uppercase tracking-wide text-ink/55">Licence</dt>
                <dd class="mt-1 font-mono text-xs">{term.rights.licence}</dd>
              </div>
              {term.rights.holder && (
                <div>
                  <dt class="text-xs font-bold uppercase tracking-wide text-ink/55">Holder</dt>
                  <dd class="mt-1">{term.rights.holder}</dd>
                </div>
              )}
              {term.rights.attribution && (
                <div>
                  <dt class="text-xs font-bold uppercase tracking-wide text-ink/55">Attribution</dt>
                  <dd class="mt-1">{term.rights.attribution}</dd>
                </div>
              )}
            </dl>
          </article>
        )}
      </div>

      <aside class="space-y-6">
        {prerequisites.length > 0 && (
          <div class="rounded-lg border border-ink/10 bg-bone p-6 shadow-soft">
            <h2 class="text-xs font-black uppercase tracking-wide text-clay">Prerequisites</h2>
            <ul class="mt-3 space-y-2">
              {prerequisites.map((p) => (
                <li>
                  {p.match
                    ? <a class="block rounded-lg bg-paper px-3 py-2 text-sm font-bold text-ink hover:bg-ink hover:text-bone" href={`/glossary/${p.match.id}`}>{p.name}</a>
                    : <span class="block rounded-lg bg-paper px-3 py-2 text-sm font-bold text-ink/62">{p.name}</span>}
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="rounded-lg border border-ink/10 bg-bone p-6 shadow-soft">
          <h2 class="text-xs font-black uppercase tracking-wide text-clay">Related terms</h2>
          {related.length === 0 ? (
            <p class="mt-3 text-sm text-ink/60">No related terms.</p>
          ) : (
            <ul class="mt-3 space-y-2">
              {related.map((r) => (
                <li>
                  {r.match
                    ? <a class="block rounded-lg bg-paper px-3 py-2 text-sm font-bold text-ink hover:bg-ink hover:text-bone" href={`/glossary/${r.match.id}`}>{r.name}</a>
                    : <span class="block rounded-lg bg-paper px-3 py-2 text-sm font-bold text-ink/62">{r.name}</span>}
                </li>
              ))}
            </ul>
          )}
        </div>

        <div class="rounded-lg border border-ink/10 bg-bone p-6 shadow-soft">
          <h2 class="text-xs font-black uppercase tracking-wide text-clay">Tags</h2>
          <div class="mt-3 flex flex-wrap gap-2">
            {term.tags.map((tag) => (
              <span class="rounded-full bg-paper px-3 py-1 text-xs font-bold text-ink/62">#{tag}</span>
            ))}
          </div>
        </div>

        <a class="block rounded-lg border border-ink/12 bg-paper px-4 py-3 text-center text-sm font-bold text-ink hover:bg-ink hover:text-bone" href="/glossary">Back to glossary</a>
      </aside>
    </div>
  </section>
</BaseLayout>

<script>
  document.addEventListener("click", async (event) => {
    const target = event.target as HTMLElement;

    const copyButton = target.closest<HTMLButtonElement>("[data-copy-prompt]");
    if (copyButton) {
      try {
        await navigator.clipboard.writeText(copyButton.dataset.copyPrompt ?? "");
        const original = copyButton.textContent;
        copyButton.textContent = "Copied";
        window.dispatchEvent(new CustomEvent("aiscreens:prompt-copied"));
        setTimeout(() => {
          copyButton.textContent = original;
        }, 1200);
      } catch {
        /* ignore */
      }
    }

    const previewButton = target.closest<HTMLButtonElement>("[data-preview-option]");
    if (previewButton) {
      const scope = previewButton.closest<HTMLElement>("[data-preview-scope]");
      if (!scope) return;
      const duration = previewButton.dataset.previewOption === "5" ? "5" : "3";
      const prompt = duration === "5" ? scope.dataset.preview5 : scope.dataset.preview3;
      const promptTarget = scope.querySelector<HTMLElement>("[data-preview-prompt]");
      if (promptTarget && prompt) promptTarget.textContent = prompt;
      scope.querySelectorAll<HTMLButtonElement>("[data-preview-option]").forEach((button) => {
        const active = button === previewButton;
        button.classList.toggle("bg-ink", active);
        button.classList.toggle("text-bone", active);
        button.classList.toggle("border", !active);
        button.classList.toggle("border-ink/12", !active);
        button.classList.toggle("text-ink/64", !active);
      });
    }
  });
</script>
