<script>
  type DirectorDemoStep = {
    label: string;
    copy: string;
    note: string;
  };

  const directorDemoSteps = JSON.parse(
    document.getElementById("landing-demo-data")?.textContent ?? "[]",
  ) as DirectorDemoStep[];

  type OnboardingItem = {
    eyebrow: string;
    title: string;
    description: string;
  };

  const onboardingFlow = JSON.parse(
    document.getElementById("onboarding-flow-data")?.textContent ?? "[]",
  ) as OnboardingItem[];

  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  document.documentElement.classList.add("motion-ready");

  if (!reducedMotion) {
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("in-view");
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.04, rootMargin: "0px 0px -4% 0px" });

    document.querySelectorAll<HTMLElement>("[data-reveal], .recipe-card, .preview-tile, .tool-card, .blog-preview-card, .plan-card").forEach((item, index) => {
      item.dataset.reveal = item.dataset.reveal ?? "";
      item.style.setProperty("--reveal-delay", `${Math.min(index % 8, 7) * 45}ms`);
      revealObserver.observe(item);
    });
  } else {
    document.querySelectorAll<HTMLElement>("[data-reveal], .recipe-card, .preview-tile, .tool-card, .blog-preview-card, .plan-card").forEach((item) => {
      item.classList.add("in-view");
    });
  }

  document.querySelectorAll<HTMLElement>("[data-landing-demo]").forEach((demo) => {
    const card = demo.querySelector<HTMLElement>(".director-demo-card");
    const label = demo.querySelector<HTMLElement>("[data-demo-label]");
    const copy = demo.querySelector<HTMLElement>("[data-demo-copy]");
    const note = demo.querySelector<HTMLElement>("[data-demo-note]");
    const progress = demo.querySelector<HTMLElement>("[data-demo-progress]");
    const buttons = Array.from(demo.querySelectorAll<HTMLButtonElement>("[data-demo-step]"));
    let active = 0;
    let timer: number | undefined;

    const setStep = (index: number) => {
      if (directorDemoSteps.length === 0) return;
      active = (index + directorDemoSteps.length) % directorDemoSteps.length;
      const step = directorDemoSteps[active];
      card?.setAttribute("data-demo-stage", String(active));
      if (label) label.textContent = step.label;
      if (copy) copy.textContent = step.copy;
      if (note) note.textContent = step.note;
      if (progress) progress.style.transform = `scaleX(${(active + 1) / directorDemoSteps.length})`;
      buttons.forEach((button, buttonIndex) => button.classList.toggle("active", buttonIndex === active));
    };

    const start = () => {
      if (reducedMotion || timer) return;
      timer = window.setInterval(() => setStep(active + 1), 2800);
    };

    const stop = () => {
      if (!timer) return;
      window.clearInterval(timer);
      timer = undefined;
    };

    buttons.forEach((button, index) => {
      button.addEventListener("click", () => {
        stop();
        setStep(index);
        start();
      });
    });

    demo.addEventListener("pointerenter", stop);
    demo.addEventListener("pointerleave", start);
    setStep(0);
    start();
  });

  document.querySelectorAll<HTMLElement>("[data-scroll-story]").forEach((story) => {
    const cards = Array.from(story.querySelectorAll<HTMLElement>("[data-story-step]"));
    const progressItems = Array.from(story.querySelectorAll<HTMLElement>("[data-story-progress]"));
    const eyebrow = story.querySelector<HTMLElement>("[data-story-eyebrow]");
    const title = story.querySelector<HTMLElement>("[data-story-title]");
    const copy = story.querySelector<HTMLElement>("[data-story-copy]");
    const visual = story.querySelector<HTMLElement>("[data-story-stage]");

    const setStoryStep = (index: number) => {
      const step = onboardingFlow[index] ?? onboardingFlow[0];
      cards.forEach((card, cardIndex) => card.classList.toggle("active", cardIndex === index));
      progressItems.forEach((item, itemIndex) => item.classList.toggle("active", itemIndex <= index));
      if (eyebrow) eyebrow.textContent = step.eyebrow;
      if (title) title.textContent = step.title;
      if (copy) copy.textContent = step.description;
      visual?.setAttribute("data-story-stage", String(index));
    };

    let scrollFrame = 0;
    const updateStoryFromScroll = () => {
      scrollFrame = 0;
      const targetY = window.innerHeight * 0.55;
      let bestIndex = 0;
      let bestDistance = Number.POSITIVE_INFINITY;
      cards.forEach((card, index) => {
        const rect = card.getBoundingClientRect();
        const center = rect.top + rect.height / 2;
        const distance = Math.abs(center - targetY);
        if (distance < bestDistance) {
          bestDistance = distance;
          bestIndex = index;
        }
      });
      setStoryStep(bestIndex);
    };

    const requestStoryUpdate = () => {
      if (scrollFrame) return;
      scrollFrame = window.requestAnimationFrame(updateStoryFromScroll);
    };

    cards.forEach((card, index) => {
      card.addEventListener("click", () => setStoryStep(index));
    });
    window.addEventListener("scroll", requestStoryUpdate, { passive: true });
    window.addEventListener("resize", requestStoryUpdate);
    setStoryStep(0);
    requestStoryUpdate();
  });

  document.querySelectorAll<HTMLElement>("[data-pipeline-board]").forEach((board) => {
    const caption = board.closest("section")?.querySelector<HTMLElement>("[data-pipeline-caption]");
    const preview = board.closest("section")?.querySelector<HTMLElement>("[data-pipeline-preview]");
    board.querySelectorAll<HTMLButtonElement>("[data-pipeline-step]").forEach((button) => {
      button.addEventListener("click", () => {
        board.querySelectorAll("[data-pipeline-step]").forEach((step) => step.classList.remove("active"));
        button.classList.add("active");
        preview?.setAttribute("data-pipeline-preview", button.dataset.pipelineStep ?? "0");
        if (caption) caption.textContent = button.dataset.caption ?? caption.textContent;
      });
    });
  });

  document.querySelectorAll<HTMLButtonElement>("[data-export-demo]").forEach((button) => {
    button.addEventListener("click", () => {
      const parent = button.closest(".model-export-demo");
      parent?.querySelectorAll("[data-export-demo]").forEach((item) => item.classList.remove("active"));
      button.classList.add("active");
      const copy = parent?.querySelector<HTMLElement>("[data-export-copy]");
      if (copy) copy.textContent = button.dataset.exportTip ?? copy.textContent;
    });
  });

  const previewObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      const video = entry.target as HTMLVideoElement;
      if (entry.isIntersecting) {
        if (!video.src && video.dataset.src) {
          video.src = video.dataset.src;
          video.load();
        }
        if (!video.poster && video.dataset.poster) {
          video.poster = video.dataset.poster;
        }
        video.play().catch(() => undefined);
      } else {
        video.pause();
      }
    });
  }, { threshold: 0.3 });

  document.querySelectorAll<HTMLVideoElement>(".preview-tile video").forEach((video) => {
    previewObserver.observe(video);
  });

  document.querySelectorAll<HTMLButtonElement>("[data-copy-text]").forEach((button) => {
    button.addEventListener("click", async () => {
      const original = button.textContent ?? "Copy Prompt";
      const text = button.dataset.copyText ?? "";
      try {
        await navigator.clipboard.writeText(text);
        button.textContent = "Copied";
        window.setTimeout(() => {
          button.textContent = original;
        }, 1600);
      } catch {
        button.textContent = "Copy failed";
        window.setTimeout(() => {
          button.textContent = original;
        }, 1600);
      }
    });
  });
</script>

