---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import OpenSource from "../../components/OpenSource.astro";
import { stats, tokens } from "../../src/site.config";
---

<BaseLayout>
  <!-- 1. Hero -->
  <Hero />

  <!-- 2. Stats strip -->
  <div
    style="
      background: #171720;
      border-top: 1px solid rgba(255,255,255,0.06);
      padding-block: clamp(20px, 3vw, 32px);
    "
  >
    <div class="container-pad">
      <div class="stats-row">
        {stats.map((stat) => (
          <div
            style="
              display: flex;
              flex-direction: column;
              align-items: center;
              gap: 5px;
              text-align: center;
            "
          >
            <span
              style="
                font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
                font-size: 32px;
                font-weight: 700;
                color: #FFFFFF;
                line-height: 1;
                letter-spacing: -0.02em;
              "
            >{stat.value}</span>
            <span
              class="font-ui"
              style="font-size: 13px; color: rgba(255,255,255,0.4); font-weight: 500;"
            >{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- 3. Beginner rescue + recipe grid -->
  <section style="background: #F8F5EF; padding-block: clamp(32px, 4vw, 56px);">
    <div class="container-pad">

      <!-- Part A: Not sure strip -->
      <div
        style="
          background: #EFE8DC;
          padding: 32px;
          border-radius: 20px;
          text-align: center;
          margin-bottom: 40px;
        "
      >
        <h2
          style="
            font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
            font-size: 24px;
            font-weight: 700;
            color: #171717;
            margin: 0 0 10px 0;
            letter-spacing: -0.01em;
          "
        >Not sure where to start?</h2>
        <p
          class="font-ui"
          style="font-size: 15px; color: #4F4A45; margin: 0 0 16px 0; line-height: 1.6;"
        >Pick the kind of video you want to make and we'll give you a shot plan with prompts.</p>
        <a
          href="/recipes"
          class="font-ui"
          style="
            color: #E4572E;
            font-size: 15px;
            font-weight: 600;
            text-decoration: none;
          "
          onmouseover="this.style.textDecoration='underline'"
          onmouseout="this.style.textDecoration='none'"
        >Browse all Shot Recipes →</a>
      </div>

      <!-- Part B: Recipe grid -->
      <div style="margin-bottom: 24px;">
        <h2
          style="
            font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: #171717;
            margin: 0 0 8px 0;
            letter-spacing: -0.02em;
          "
        >What do you want to make?</h2>
        <p
          class="font-ui"
          style="font-size: 16px; color: #4F4A45; margin: 0; line-height: 1.6;"
        >Choose a video type and get a beginner-friendly shot plan with copyable AI prompts.</p>
      </div>

      <div class="recipe-grid">
        {[
          { emoji: "☕", title: "Coffee Shop Reel", shots: "7 shots", level: "Beginner" },
          { emoji: "📦", title: "Product Video", shots: "6 shots", level: "Beginner" },
          { emoji: "🌍", title: "Travel Montage", shots: "7 shots", level: "Beginner" },
          { emoji: "🍽", title: "Food Video", shots: "6 shots", level: "Beginner" },
          { emoji: "🎤", title: "Interview", shots: "7 shots", level: "Intermediate" },
          { emoji: "📚", title: "Tutorial", shots: "6 shots", level: "Beginner" },
          { emoji: "🏠", title: "Real Estate Tour", shots: "7 shots", level: "Beginner" },
          { emoji: "💪", title: "Fitness Demo", shots: "6 shots", level: "Beginner" },
        ].map((card) => (
          <a
            href="/recipes"
            class="recipe-card"
            style="
              background: #ffffff;
              border: 1.5px solid #E6DDD1;
              border-radius: 16px;
              padding: 20px;
              text-decoration: none;
              display: flex;
              flex-direction: column;
              gap: 8px;
              transition: box-shadow 0.15s, border-color 0.15s, transform 0.15s;
              cursor: pointer;
            "
            onmouseover="this.style.boxShadow='0 8px 24px rgba(0,0,0,0.08)'; this.style.borderColor='#D8CFC3'; this.style.transform='translateY(-2px)'"
            onmouseout="this.style.boxShadow='none'; this.style.borderColor='#E6DDD1'; this.style.transform='translateY(0)'"
          >
            <span style="font-size: 48px; line-height: 1;">{card.emoji}</span>
            <h3
              style="
                font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
                font-size: 16px;
                font-weight: 700;
                color: #171717;
                margin: 0;
              "
            >{card.title}</h3>
            <span
              class="font-ui"
              style="font-size: 12px; color: #7A7268;"
            >{card.shots} · {card.level}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 4+5. Example + How it works (side-by-side) -->
  <section style="background: #FFFFFF; padding-block: clamp(48px, 6vw, 80px);">
    <div class="container-pad">
      <div class="example-split">

        <!-- LEFT: Real example -->
        <div class="example-left">
          <span class="font-ui" style="font-size: 11px; font-weight: 700; color: #E4572E; text-transform: uppercase; letter-spacing: 0.12em; display: block; margin-bottom: 14px;">Live Example</span>
          <h2 style="font-family: 'Space Grotesk', sans-serif; font-size: clamp(22px, 2.8vw, 30px); font-weight: 700; color: #171717; margin: 0 0 8px; letter-spacing: -0.02em;">
            Here is what CineCards actually does
          </h2>
          <p class="font-ui" style="font-size: 15px; color: #7A7268; margin: 0 0 24px; line-height: 1.6;">
            You give an idea. We give a shot plan with prompts.
          </p>

          <!-- Idea box -->
          <div style="background: #F8F5EF; border: 1.5px solid #E6DDD1; border-radius: 14px; padding: 18px 22px; margin-bottom: 20px;">
            <span class="font-ui" style="font-size: 11px; font-weight: 600; color: #7A7268; text-transform: uppercase; letter-spacing: 0.1em; display: block; margin-bottom: 6px;">Your idea</span>
            <p style="font-family: 'Space Grotesk', sans-serif; font-size: 20px; font-weight: 700; color: #171717; margin: 0 0 10px;">"A cozy coffee shop video"</p>
            <span class="font-ui" style="font-size: 13px; color: #4F4A45; display: flex; align-items: center; gap: 6px;">
              <span style="color: #E4572E; font-weight: 700; font-size: 16px;">↓</span>
              CineCards turns it into:
            </span>
          </div>

          <!-- Timeline -->
          <div style="margin-bottom: 20px;">
            {[
              { n: "1", type: "Wide Shot",   desc: "Full café setting",       dur: "3s" },
              { n: "2", type: "Medium Shot", desc: "Introduce the barista",   dur: "3s" },
              { n: "3", type: "Close-Up",    desc: "Coffee being poured",     dur: "5s", active: true },
              { n: "4", type: "Detail Shot", desc: "Steam and latte art",     dur: "3s" },
              { n: "5", type: "Final Shot",  desc: "Customer enjoying coffee",dur: "5s" },
            ].map((shot) => (
              <div style={`display: flex; align-items: center; gap: 14px; padding: 11px 0; border-bottom: 1px solid #F0EAE2;`}>
                <div class="font-ui" style={`width: 32px; height: 32px; border-radius: 50%; background: ${shot.active ? '#E4572E' : '#F8F5EF'}; color: ${shot.active ? '#fff' : '#7A7268'}; font-size: 12px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; border: ${shot.active ? 'none' : '1.5px solid #E6DDD1'};`}>{shot.n}</div>
                <div style="flex: 1; min-width: 0;">
                  <span style="font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 700; color: #171717;">{shot.type}</span>
                  <span class="font-ui" style="font-size: 13px; color: #7A7268; margin-left: 8px;">{shot.desc}</span>
                </div>
                <span class="font-ui" style="font-size: 12px; font-weight: 600; color: #7A7268; background: #F8F5EF; border: 1px solid #E6DDD1; border-radius: 6px; padding: 2px 9px; flex-shrink: 0;">{shot.dur}</span>
              </div>
            ))}
          </div>

          <!-- Dark prompt block -->
          <div style="background: #0F0F13; border-radius: 12px; padding: 18px 20px; margin-bottom: 20px;">
            <span class="font-ui" style="font-size: 9px; font-weight: 600; color: rgba(255,255,255,0.35); letter-spacing: 0.14em; text-transform: uppercase; display: block; margin-bottom: 8px;">AI Prompt — Shot 3</span>
            <p class="font-mono" style="font-size: 12.5px; line-height: 1.7; color: rgba(255,255,255,0.82); margin: 0 0 14px;">
              cinematic close-up of hot coffee being poured into a ceramic cup,<br />
              soft morning light, cozy café background, shallow DOF, 5 seconds
            </p>
            <button class="font-ui" onclick="navigator.clipboard.writeText('cinematic close-up of hot coffee being poured into a ceramic cup, soft morning light, cozy café background, shallow DOF, 5 seconds').then(()=>{this.textContent='Copied!';setTimeout(()=>{this.textContent='Copy Prompt'},2000)})" style="background: rgba(255,255,255,0.09); color: rgba(255,255,255,0.78); border: 1px solid rgba(255,255,255,0.14); border-radius: 8px; padding: 6px 14px; font-size: 12px; font-weight: 600; cursor: pointer; transition: background 0.15s;" onmouseover="this.style.background='rgba(255,255,255,0.16)'" onmouseout="this.style.background='rgba(255,255,255,0.09)'">Copy Prompt</button>
          </div>

          <!-- CTAs -->
          <div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
            <a href="/planner?topic=coffee+shop+reel" class="font-ui focus-ring" style="display:inline-flex;align-items:center;justify-content:center;background:#E4572E;color:#fff;font-size:14px;font-weight:700;padding:0 22px;height:44px;border-radius:999px;text-decoration:none;white-space:nowrap;transition:background 0.15s;" onmouseover="this.style.background='#B83A1F'" onmouseout="this.style.background='#E4572E'">Try With My Idea →</a>
            <a href="/recipes" class="font-ui focus-ring" style="display:inline-flex;align-items:center;color:#7A7268;font-size:14px;font-weight:600;text-decoration:none;" onmouseover="this.style.color='#171717'" onmouseout="this.style.color='#7A7268'">Browse recipes →</a>
          </div>
        </div>

        <!-- RIGHT: How it works -->
        <div class="example-right">
          <div style="position: sticky; top: 88px;">
            <span class="font-ui" style="font-size: 11px; font-weight: 700; color: #E4572E; text-transform: uppercase; letter-spacing: 0.12em; display: block; margin-bottom: 14px;">How It Works</span>
            <h2 style="font-family: 'Space Grotesk', sans-serif; font-size: clamp(22px, 2.8vw, 30px); font-weight: 700; color: #171717; margin: 0 0 8px; letter-spacing: -0.02em;">
              Three steps to AI-ready shots
            </h2>
            <p class="font-ui" style="font-size: 15px; color: #7A7268; margin: 0 0 36px; line-height: 1.6;">
              From zero to copy-ready prompts in minutes.
            </p>

            <!-- Steps -->
            <div style="display: flex; flex-direction: column; gap: 0;">
              {[
                {
                  n: "1",
                  title: "Learn a film word",
                  desc: "Pick any of 124 terms — shots, angles, lighting, movement. Each card shows what it is, why it matters, and its AI prompt.",
                  href: "/glossary",
                  link: "Browse Glossary →",
                },
                {
                  n: "2",
                  title: "Type your video idea",
                  desc: "Enter a topic — 'coffee shop reel', 'product launch', 'travel montage'. We build a prioritised shot plan instantly.",
                  href: "/planner",
                  link: "Open Planner →",
                },
                {
                  n: "3",
                  title: "Copy your AI prompts",
                  desc: "Each shot comes with a ready-to-paste prompt for Runway, Pika, or Stable Video. Copy one or all.",
                  href: "/recipes",
                  link: "See a Recipe →",
                },
              ].map((step, i) => (
                <div style={`display: flex; gap: 20px; padding-bottom: 32px; ${i < 2 ? 'border-bottom: 1px solid #F0EAE2; margin-bottom: 32px;' : ''}`}>
                  <!-- Number + vertical line -->
                  <div style="display: flex; flex-direction: column; align-items: center; gap: 0; flex-shrink: 0;">
                    <div class="font-ui" style="width: 40px; height: 40px; border-radius: 50%; background: #E4572E; color: #fff; font-size: 15px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">{step.n}</div>
                    {i < 2 && <div style="width: 2px; flex: 1; background: #F0EAE2; margin-top: 8px; min-height: 24px;"></div>}
                  </div>
                  <div style="padding-top: 8px;">
                    <h3 style="font-family: 'Space Grotesk', sans-serif; font-size: 17px; font-weight: 700; color: #171717; margin: 0 0 8px;">{step.title}</h3>
                    <p class="font-ui" style="font-size: 14px; color: #4F4A45; line-height: 1.65; margin: 0 0 12px;">{step.desc}</p>
                    <a href={step.href} class="font-ui" style="font-size: 13px; font-weight: 600; color: #E4572E; text-decoration: none;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">{step.link}</a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 6. Beginner Path -->
  <section style="background: #EFE8DC; padding-block: 32px;">
    <div class="container-pad">
      <!-- Eyebrow -->
      <span
        class="font-ui"
        style="
          display: block;
          font-size: 11px;
          font-weight: 700;
          color: #E4572E;
          text-transform: uppercase;
          letter-spacing: 0.12em;
          margin-bottom: 12px;
        "
      >NEW TO VIDEO CREATION?</span>

      <h2
        style="
          font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
          font-size: 28px;
          font-weight: 700;
          color: #171717;
          margin: 0 0 10px 0;
          letter-spacing: -0.01em;
        "
      >Start here. Learn the basics in order.</h2>
      <p
        class="font-ui"
        style="font-size: 15px; color: #4F4A45; margin: 0 0 20px 0; line-height: 1.6; max-width: 560px;"
      >You do not need to know film words. Start from zero and build up.</p>

      <!-- Step pills -->
      <div class="beginner-pills">
        {[
          { n: "1", label: "What is a shot?" },
          { n: "2", label: "Wide, Medium, Close-Up" },
          { n: "3", label: "Camera angles" },
          { n: "4", label: "Camera movement" },
          { n: "5", label: "Basic lighting" },
          { n: "6", label: "Your first AI prompt" },
        ].map((pill) => (
          <div
            class="font-ui"
            style="
              display: inline-flex;
              align-items: center;
              gap: 10px;
              border: 1.5px solid #D8CFC3;
              border-radius: 16px;
              padding: 10px 16px;
              background: #ffffff;
            "
          >
            <span
              style="
                width: 22px;
                height: 22px;
                border-radius: 50%;
                background: #E4572E;
                color: #ffffff;
                font-size: 11px;
                font-weight: 700;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
              "
            >{pill.n}</span>
            <span style="font-size: 13px; font-weight: 600; color: #171717;">{pill.label}</span>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div style="margin-top: 20px;">
        <a
          href="/learn"
          class="font-ui focus-ring"
          style="
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #E4572E;
            color: #ffffff;
            font-size: 15px;
            font-weight: 700;
            padding: 0 28px;
            height: 48px;
            border-radius: 999px;
            text-decoration: none;
            transition: background 0.15s;
          "
          onmouseover="this.style.background='#B83A1F'"
          onmouseout="this.style.background='#E4572E'"
        >Start Beginner Path</a>
      </div>
    </div>
  </section>

  <!-- 7. Main tools grid -->
  <section style="background: #ffffff; padding-block: clamp(32px, 4vw, 56px);">
    <div class="container-pad">
      <h2
        style="
          font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
          font-size: clamp(22px, 3vw, 28px);
          font-weight: 700;
          color: #171717;
          margin: 0 0 24px 0;
          letter-spacing: -0.02em;
        "
      >Everything in one place</h2>

      <div class="tools-grid">
        {[
          {
            icon: "📚",
            title: "Learn Film Words",
            desc: "Search and browse 124 film and video terms.",
            href: "/glossary",
          },
          {
            icon: "🎬",
            title: "Create a Video Plan",
            desc: "Type your idea, get a shot plan and prompts.",
            href: "/planner",
          },
          {
            icon: "🧠",
            title: "Practice",
            desc: "Quiz yourself. Track what you know.",
            href: "/learn",
          },
          {
            icon: "🍳",
            title: "Shot Recipes",
            desc: "Ready-made shot plans for real video types.",
            href: "/recipes",
          },
        ].map((tool) => (
          <a
            href={tool.href}
            style="
              background: #ffffff;
              border: 1.5px solid #E6DDD1;
              border-radius: 16px;
              padding: 24px;
              text-decoration: none;
              display: flex;
              flex-direction: column;
              gap: 10px;
              transition: box-shadow 0.15s, border-color 0.15s, transform 0.15s;
            "
            onmouseover="this.style.boxShadow='0 8px 24px rgba(0,0,0,0.08)'; this.style.borderColor='#D8CFC3'; this.style.transform='translateY(-2px)'"
            onmouseout="this.style.boxShadow='none'; this.style.borderColor='#E6DDD1'; this.style.transform='translateY(0)'"
          >
            <span style="font-size: 32px; line-height: 1;">{tool.icon}</span>
            <h3
              style="
                font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
                font-size: 18px;
                font-weight: 700;
                color: #171717;
                margin: 0;
              "
            >{tool.title}</h3>
            <p
              class="font-ui"
              style="font-size: 14px; color: #4F4A45; line-height: 1.6; margin: 0; flex: 1;"
            >{tool.desc}</p>
            <span
              style="
                color: #E4572E;
                font-size: 18px;
                font-weight: 700;
                display: block;
              "
            >→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 8. Open Source -->
  <OpenSource />

</BaseLayout>

<style>
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 480px) {
    .stats-row {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }

  .recipe-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media (min-width: 900px) {
    .recipe-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .example-split {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 80px;
    align-items: start;
  }

  .example-right {
    border-left: 1px solid #F0EAE2;
    padding-left: 64px;
  }

  @media (max-width: 900px) {
    .example-split {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .example-right {
      border-left: none;
      padding-left: 0;
      border-top: 1px solid #F0EAE2;
      padding-top: 40px;
    }
  }

  .beginner-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media (min-width: 900px) {
    .tools-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 480px) {
    .tools-grid {
      grid-template-columns: 1fr;
    }

    .recipe-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
