---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import OpenSource from "../../components/OpenSource.astro";
import MediaLoop from "../../components/MediaLoop.astro";
import { stats } from "../../src/site.config";
import { getCollection } from "astro:content";
import monetization from "../../data/monetization.json";
import promptPacks from "../../data/promptPacks.json";
import siteMedia from "../../data/siteMedia.json";
import { getAllTerms } from "../../lib/termSearch";
import type { PromptPack } from "../../types/pack";

const blogPosts = await getCollection("blog", ({ data }) => !data.draft);
const latestPosts = blogPosts
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .filter(p => p.data.featured)
  .slice(0, 3);
const previewPosts = latestPosts.length >= 3 ? latestPosts : blogPosts.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()).slice(0, 3);
const previewTerms = getAllTerms().filter((term) => term.previewVideoUrl).slice(0, 6);
const packs = promptPacks as PromptPack[];

const categoryColors: Record<string, string> = {
  shots:          "#B83A1F",
  lighting:       "#9A5B00",
  movement:       "#6D3EDB",
  editing:        "#047857",
  "ai-prompting": "#1D4ED8",
};

const { homepageOffer } = monetization as {
  homepageOffer: {
    eyebrow: string;
    title: string;
    description: string;
    plans: Array<{
      name: string;
      price: string;
      description: string;
      cta: string;
      href: string;
    }>;
  };
};

const { onboardingFlow } = monetization as {
  onboardingFlow: Array<{
    step: string;
    eyebrow: string;
    title: string;
    description: string;
    action: string;
    href: string;
  }>;
};

const { landingDemo } = monetization as {
  landingDemo: {
    eyebrow: string;
    title: string;
    description: string;
    steps: Array<{
      n: string;
      title: string;
      label: string;
      copy: string;
      note: string;
    }>;
  };
};

const { audiencePaths } = monetization as {
  audiencePaths: Array<{
    label: string;
    problem: string;
    workflow: string;
    cta: string;
    href: string;
  }>;
};

const audienceVisuals = [
  {
    label: "Course creator",
    setting: "Lesson hook",
    subject: "Tutor",
    beats: ["Topic", "Demo", "CTA"],
  },
  {
    label: "Ecommerce brand",
    setting: "Product reel",
    subject: "Hero item",
    beats: ["Lock", "Detail", "Payoff"],
  },
  {
    label: "Solo creator",
    setting: "Short idea",
    subject: "Creator",
    beats: ["Recipe", "Prompt", "Post"],
  },
  {
    label: "Local business",
    setting: "Service promo",
    subject: "Owner",
    beats: ["Place", "Proof", "Offer"],
  },
];

const { workflowDemo } = monetization as {
  workflowDemo: {
    eyebrow: string;
    title: string;
    description: string;
    steps: Array<{
      step: string;
      title: string;
      body: string;
      caption: string;
    }>;
    modelTips: Array<{
      model: string;
      copy: string;
    }>;
  };
};

const { creditFixer } = monetization as {
  creditFixer: {
    eyebrow: string;
    title: string;
    description: string;
    weakLabel: string;
    weakPrompt: string;
    rewriteLabel: string;
    rewritePrompt: string;
    scores: Array<{
      label: string;
      value: string;
    }>;
  };
};

const { previewWall } = monetization as {
  previewWall: {
    eyebrow: string;
    title: string;
    description: string;
    ctaLabel: string;
    ctaHref: string;
  };
};

const { homepageRecipes } = monetization as {
  homepageRecipes: {
    title: string;
    description: string;
    ctaLabel: string;
    ctaHref: string;
    gridTitle: string;
    gridDescription: string;
    painPoints: Array<{
      title: string;
      description: string;
    }>;
  };
};

const { liveExample } = monetization as {
  liveExample: {
    eyebrow: string;
    title: string;
    description: string;
    ideaLabel: string;
    idea: string;
    ideaResult: string;
    promptLabel: string;
    prompt: string;
    primaryCta: { label: string; href: string };
    secondaryCta: { label: string; href: string };
    shots: Array<{
      n: string;
      type: string;
      description: string;
      duration: string;
      active?: boolean;
    }>;
  };
};

const { workflowSteps } = monetization as {
  workflowSteps: {
    eyebrow: string;
    title: string;
    description: string;
    steps: Array<{
      n: string;
      title: string;
      description: string;
      href: string;
      link: string;
    }>;
  };
};

const { beginnerPath } = monetization as {
  beginnerPath: {
    eyebrow: string;
    title: string;
    description: string;
    ctaLabel: string;
    ctaHref: string;
    items: Array<{
      n: string;
      label: string;
      detail: string;
    }>;
  };
};

const { toolGrid } = monetization as {
  toolGrid: {
    title: string;
    items: Array<{
      label: string;
      title: string;
      description: string;
      href: string;
      meta: string;
    }>;
  };
};

const recipeVisuals = [
  {
    label: "Cafe reel",
    accent: "#B83A1F",
    soft: "#F6C2A5",
    scene: "cafe",
    setting: "Morning cafe launch",
    shots: ["Exterior", "Barista", "Pour"],
    image: "/images/home/recipes/coffee-shop-reel.webp",
  },
  {
    label: "Dialogue",
    accent: "#6D3EDB",
    soft: "#D8C9FF",
    scene: "dialogue",
    setting: "Two-person coverage",
    shots: ["Wide", "Over shoulder", "Reaction"],
    image: "/images/home/recipes/two-person-dialogue.webp",
  },
  {
    label: "Product",
    accent: "#047857",
    soft: "#B7F7DA",
    scene: "product",
    setting: "Macro product hero",
    shots: ["Hero", "Texture", "Payoff"],
    image: "/images/home/recipes/product-macro-hero.webp",
  },
  {
    label: "Travel",
    accent: "#1D4ED8",
    soft: "#BBD5FF",
    scene: "travel",
    setting: "Sunrise travel arc",
    shots: ["Place", "Move", "Vista"],
    image: "/images/home/recipes/travel-sunrise-montage.webp",
  },
  {
    label: "Tutorial",
    accent: "#9A5B00",
    soft: "#FFE0A3",
    scene: "tutorial",
    setting: "Teach one action",
    shots: ["Face", "Hands", "Result"],
    image: "/images/home/recipes/tutorial-talking-head.webp",
  },
  {
    label: "Interview",
    accent: "#B83280",
    soft: "#FFC1DD",
    scene: "interview",
    setting: "Founder story support",
    shots: ["Subject", "B-roll", "Detail"],
    image: "/images/home/recipes/interview-b-roll.webp",
  },
  {
    label: "Action",
    accent: "#B91C1C",
    soft: "#FFC1BC",
    scene: "action",
    setting: "Chase with clean direction",
    shots: ["Setup", "Pursuit", "Cutaway"],
    image: "/images/home/recipes/cinematic-chase.webp",
  },
  {
    label: "Lifestyle",
    accent: "#0F766E",
    soft: "#B7F3ED",
    scene: "lifestyle",
    setting: "Morning routine flow",
    shots: ["Room", "Habit", "Detail"],
    image: "/images/home/recipes/lifestyle-morning-routine.webp",
  },
];

const homepageRecipeCards = packs.slice(0, 8).map((pack, index) => ({
  ...pack,
  visual: recipeVisuals[index % recipeVisuals.length],
  level: index < 5 ? "Free starter" : "Creator pack",
  shotCount: pack.items.length,
}));

const homeTools = toolGrid.items.map((tool) => ({
  ...tool,
  meta: tool.meta === "terms" ? `${stats[0]?.value ?? "124"} terms` : tool.meta === "packs" ? `${packs.length} packs` : tool.meta,
}));

const planVisuals = [
  {
    label: "Free path",
    title: "Learn + plan",
    steps: ["Glossary", "Recipe", "Planner"],
    image: "/images/home/tools/learn-language.webp",
  },
  {
    label: "Creator path",
    title: "Save better prompts",
    steps: ["Variants", "Model export", "Preview"],
    image: "/images/home/workflow-storyboard-desk.webp",
  },
  {
    label: "Service path",
    title: "Done-for-you pack",
    steps: ["Brief", "Shot plan", "Retry notes"],
    image: "/images/home/director-demo-bakery.webp",
  },
];

const toolVisualImages = [
  "/images/home/tools/learn-language.webp",
  "/images/home/tools/plan-sequence.webp",
  "/images/home/tools/practice-progress.webp",
  "/images/home/tools/use-recipe.webp",
];

const homeToolCards = homeTools.map((tool, index) => ({
  ...tool,
  image: toolVisualImages[index % toolVisualImages.length],
}));
---

<BaseLayout preloadImage="/images/home/posters/hero-director-loop.webp" preloadImageMedia="(min-width: 901px)">
  <!-- 1. Hero -->
  <Hero />

  <!-- 2. Stats strip -->
  <div
    style="
      background: #171720;
      border-top: 1px solid rgba(255,255,255,0.06);
      padding-block: clamp(20px, 3vw, 32px);
    "
  >
    <div class="container-pad">
      <div class="stats-row">
        {stats.map((stat) => (
          <div
            style="
              display: flex;
              flex-direction: column;
              align-items: center;
              gap: 5px;
              text-align: center;
            "
          >
            <span
              style="
                font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
                font-size: 32px;
                font-weight: 700;
                color: #FFFFFF;
                line-height: 1;
                letter-spacing: -0.02em;
              "
            >{stat.value}</span>
            <span
              class="font-ui"
              style="font-size: 13px; color: rgba(255,255,255,0.62); font-weight: 500;"
            >{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- 2b. Landing value demo -->
  <section class="landing-demo" data-landing-demo data-reveal>
    <div class="container-pad landing-demo-grid">
      <div class="landing-demo-copy">
        <span class="section-kicker">{landingDemo.eyebrow}</span>
        <h2>{landingDemo.title}</h2>
        <p>{landingDemo.description}</p>
        <div class="landing-demo-actions">
          {landingDemo.steps.map((step, index) => (
            <button class={index === 0 ? "active" : ""} type="button" data-demo-step={index}>
              <span>{step.n}</span>
              {step.title}
            </button>
          ))}
        </div>
      </div>

      <div class="director-demo-card" data-demo-stage="0">
        <div class="demo-topbar">
          <span>aiscreens director</span>
          <i></i>
        </div>
        <div class="demo-stage">
          <MediaLoop media={siteMedia.home.workflow} className="demo-media-loop" />
        </div>
        <div class="demo-output">
          <span data-demo-label>{landingDemo.steps[0]?.label}</span>
          <strong data-demo-copy>{landingDemo.steps[0]?.copy}</strong>
          <p data-demo-note>{landingDemo.steps[0]?.note}</p>
          <div class="demo-progress"><i data-demo-progress></i></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2c. Scroll onboarding story -->
  <section class="scroll-story" data-scroll-story>
    <div class="container-pad scroll-story-grid">
      <div class="scroll-story-sticky">
        <span class="section-kicker">Scroll onboarding</span>
        <h2>Follow the path from confused creator to paid-ready workflow.</h2>
        <p>
          The site should teach without feeling like a manual. Each scroll beat shows what the user gets next and why it matters.
        </p>
        <div class="story-screen">
          <div class="story-screen-top">
            <span data-story-eyebrow>{onboardingFlow[0]?.eyebrow}</span>
            <i></i>
          </div>
          <strong data-story-title>{onboardingFlow[0]?.title}</strong>
          <p data-story-copy>{onboardingFlow[0]?.description}</p>
          <div class="story-visual" data-story-stage="0">
            <MediaLoop media={siteMedia.home.workflow} className="story-media-loop" />
          </div>
        </div>
        <div class="story-progress" aria-hidden="true">
          {onboardingFlow.map((item, index) => (
            <span class={index === 0 ? "active" : ""} data-story-progress={index}>{item.step}</span>
          ))}
        </div>
      </div>

      <div class="scroll-story-steps">
        {onboardingFlow.map((item, index) => (
          <article class={index === 0 ? "story-step active" : "story-step"} data-story-step={index}>
            <span>{item.step}</span>
            <small>{item.eyebrow}</small>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <a class="focus-ring" href={item.href}>{item.action} →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. Interactive direction pipeline -->
  <section class="direction-lab" data-reveal>
    <div class="container-pad">
      <div class="section-head">
        <span>{workflowDemo.eyebrow}</span>
        <h2>{workflowDemo.title}</h2>
        <p>{workflowDemo.description}</p>
      </div>

      <div class="direction-grid" data-reveal>
        <div class="pipeline-board" data-pipeline-board>
          {workflowDemo.steps.map((item, index) => (
            <button class={`pipeline-step ${index === 0 ? "active" : ""}`} type="button" data-pipeline-step={index} data-caption={item.caption}>
              <span>{item.step}</span>
              <strong>{item.title}</strong>
              <p>{item.body}</p>
            </button>
          ))}
        </div>

        <div class="motion-preview">
          <div class="preview-screen" data-pipeline-preview="0">
            <MediaLoop media={siteMedia.home.workflow} className="pipeline-media-loop" />
            <p data-pipeline-caption>Start from the user’s real goal, not a random cinematic adjective stack.</p>
          </div>
          <div class="model-export-demo">
            <span>Export target</span>
            <div>
              {workflowDemo.modelTips.map((tip, index) => (
                <button type="button" class={index === 0 ? "active" : ""} data-export-demo={tip.model} data-export-tip={tip.copy}>{tip.model}</button>
              ))}
            </div>
            <p data-export-copy>{workflowDemo.modelTips[0]?.copy}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Credit waste fixer -->
  <section class="credit-fixer" data-reveal>
    <div class="container-pad credit-grid">
      <div>
        <span class="mini-eyebrow">{creditFixer.eyebrow}</span>
        <h2>{creditFixer.title}</h2>
        <p>{creditFixer.description}</p>
      </div>
      <div class="fixer-card" data-fixer-card>
        <div class="bad-prompt">
          <span>{creditFixer.weakLabel}</span>
          <p>{creditFixer.weakPrompt}</p>
        </div>
        <div class="score-list">
          {creditFixer.scores.map((score) => (
            <div>
              <span>{score.label}</span>
              <i style={`--score:${score.value}`}></i>
              <strong>{score.value}</strong>
            </div>
          ))}
        </div>
        <div class="fixed-prompt">
          <span>{creditFixer.rewriteLabel}</span>
          <p>{creditFixer.rewritePrompt}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Preview video wall -->
  <section class="preview-wall-section" data-reveal>
    <div class="container-pad">
      <div class="section-head compact">
        <span>{previewWall.eyebrow}</span>
        <h2>{previewWall.title}</h2>
        <p>{previewWall.description}</p>
      </div>
      <div class="preview-wall">
        {previewTerms.map((term) => (
          <a href={`/glossary/${term.id}`} class="preview-tile" aria-label={`Watch ${term.name} motion preview and open glossary term`}>
            <video
              data-src={term.previewVideoUrl}
              muted
              playsinline
              loop
              preload="none"
              data-poster={term.assets?.find((asset) => asset.type === "image" || asset.type === "thumbnail")?.url.replace(/-detail(\.[a-z]+)$/i, "-card$1")}
              aria-label={`Silent motion preview of ${term.name}`}
            >
              <track kind="captions" src="/captions/silent-preview.vtt" srclang="en" label="No dialogue" />
            </video>
            <div>
              <strong>{term.name}</strong>
              <span>{term.category}</span>
            </div>
          </a>
        ))}
      </div>
      <div class="preview-wall-action">
        <a class="focus-ring" href={previewWall.ctaHref}>{previewWall.ctaLabel} →</a>
      </div>
    </div>
  </section>

  <!-- 3. Beginner rescue + recipe grid -->
  <section style="background: #F8F5EF; padding-block: clamp(32px, 4vw, 56px);">
    <div class="container-pad">

      <!-- Part A: Not sure strip -->
      <div
        style="
          background: #EFE8DC;
          padding: 32px;
          border-radius: 20px;
          text-align: center;
          margin-bottom: 40px;
        "
      >
        <h2
          style="
            font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
            font-size: 24px;
            font-weight: 700;
            color: #171717;
            margin: 0 0 10px 0;
            letter-spacing: -0.01em;
          "
        >{homepageRecipes.title}</h2>
        <p
          class="font-ui"
          style="font-size: 15px; color: #4F4A45; margin: 0 0 16px 0; line-height: 1.6;"
        >{homepageRecipes.description}</p>
        <a
          href={homepageRecipes.ctaHref}
          class="font-ui inline-link"
          style="
            color: #B83A1F;
            font-size: 15px;
            font-weight: 600;
            text-decoration: none;
          "
        >{homepageRecipes.ctaLabel} →</a>
      </div>

      <div class="pain-grid" style="margin-bottom: 40px;">
        {homepageRecipes.painPoints.map((pain) => (
          <div style="background:#fff;border:1px solid #E6DDD1;border-radius:12px;padding:18px;">
            <h3 style="font-family:'Space Grotesk',sans-serif;font-size:16px;font-weight:800;color:#171717;margin:0 0 8px;">{pain.title}</h3>
            <p class="font-ui" style="font-size:14px;line-height:1.6;color:#4F4A45;margin:0;">{pain.description}</p>
          </div>
        ))}
      </div>

      <!-- Part B: Recipe grid -->
      <div style="margin-bottom: 24px;">
        <h2
          style="
            font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: #171717;
            margin: 0 0 8px 0;
            letter-spacing: -0.02em;
          "
        >{homepageRecipes.gridTitle}</h2>
        <p
          class="font-ui"
          style="font-size: 16px; color: #4F4A45; margin: 0; line-height: 1.6;"
        >{homepageRecipes.gridDescription}</p>
      </div>

      <div class="recipe-motion-callout">
        <MediaLoop media={siteMedia.home.recipes} className="recipe-motion-loop" />
        <div>
          <span>Recipe preview</span>
          <strong>Pick a real video job, then copy a usable shot plan.</strong>
          <p>For beginners, the recipe is the fastest path: choose cafe, product, tutorial, travel, interview, or local business before writing a prompt.</p>
        </div>
      </div>

      <div class="recipe-grid">
        {homepageRecipeCards.map((card, index) => (
          <a
            href={`/recipes#recipe-${card.id}`}
            class="recipe-card"
            style={`--card-accent:${card.visual.accent}; --card-soft:${card.visual.soft};`}
          >
            <div class="recipe-cover" data-scene={card.visual.scene}>
              <img
                src={card.visual.image}
                alt=""
                class="recipe-cover-image"
                loading="lazy"
                decoding="async"
                width="720"
                height="405"
              />
              <div class="recipe-cover-top">
                <span>{card.visual.label}</span>
                <small>{card.visual.setting}</small>
              </div>
              <div class="recipe-shot-strip" aria-label={`${card.name} shot sequence preview`}>
                {card.visual.shots.map((shot, shotIndex) => (
                  <span>
                    <b>{`0${shotIndex + 1}`}</b>
                    {shot}
                  </span>
                ))}
              </div>
            </div>
            <div class="recipe-card-body">
              <div class="recipe-card-meta">
                <span>{card.shotCount} shot plan</span>
                <span>{card.level}</span>
              </div>
              <h3>{card.name}</h3>
              <p>{card.useCase}</p>
              <div class="recipe-card-footer">
                <span>{index + 1 < 10 ? `0${index + 1}` : index + 1}</span>
                <strong>Open recipe</strong>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 4+5. Example + How it works (side-by-side) -->
  <section class="live-example-section">
    <div class="container-pad">
      <div class="example-split">

        <!-- LEFT: Real example -->
        <div class="example-left">
          <span class="section-kicker">{liveExample.eyebrow}</span>
          <h2>
            {liveExample.title}
          </h2>
          <p>
            {liveExample.description}
          </p>

          <!-- Idea box -->
          <div class="idea-card">
            <span>{liveExample.ideaLabel}</span>
            <p>{liveExample.idea}</p>
            <small>
              {liveExample.ideaResult}
            </small>
          </div>

          <!-- Timeline -->
          <div class="shot-timeline">
            {liveExample.shots.map((shot) => (
              <div class={`shot-row ${shot.active ? "active" : ""}`}>
                <div class="shot-number">{shot.n}</div>
                <div>
                  <strong>{shot.type}</strong>
                  <span>{shot.description}</span>
                </div>
                <em>{shot.duration}</em>
              </div>
            ))}
          </div>

          <!-- Dark prompt block -->
          <div class="prompt-card">
            <span>{liveExample.promptLabel}</span>
            <p>{liveExample.prompt}</p>
            <button class="copy-prompt-button" type="button" data-copy-text={liveExample.prompt}>Copy Prompt</button>
          </div>

          <!-- CTAs -->
          <div class="example-actions">
            <a href={liveExample.primaryCta.href} class="primary-pill focus-ring">{liveExample.primaryCta.label} →</a>
            <a href={liveExample.secondaryCta.href} class="secondary-link focus-ring">{liveExample.secondaryCta.label} →</a>
          </div>
        </div>

        <!-- RIGHT: How it works -->
        <div class="example-right">
          <div class="workflow-panel">
            <span class="section-kicker">{workflowSteps.eyebrow}</span>
            <h2>
              {workflowSteps.title}
            </h2>
            <p>
              {workflowSteps.description}
            </p>

            <!-- Steps -->
            <div class="workflow-steps">
              {workflowSteps.steps.map((step) => (
                <div class="workflow-step">
                  <span>{step.n}</span>
                  <h3>{step.title}</h3>
                  <p>{step.description}</p>
                  <a href={step.href}>{step.link} →</a>
                </div>
              ))}
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 6. Beginner Path -->
  <section class="beginner-path-section">
