---
import BaseLayout from "../layouts/BaseLayout.astro";
import MediaLoop from "../../components/MediaLoop.astro";
import monetization from "../../data/monetization.json";
import promptPacks from "../../data/promptPacks.json";
import siteMedia from "../../data/siteMedia.json";
import { getAllTerms } from "../../lib/termSearch";
import { buildPrompt } from "../../lib/promptBuilder";
import type { PromptPack } from "../../types/pack";
import type { Term } from "../../types/term";

const packs = promptPacks as PromptPack[];
const monetizationConfig = monetization as {
  recipeService: {
    eyebrow: string;
    title: string;
    description: string;
    primaryCta: { label: string; href: string };
    secondaryCta: { label: string; href: string };
  };
  recipeTiers: Array<{
    label: string;
    tone: string;
    maxPackIndexExclusive?: number;
  }>;
  recipeSegments: Array<{
    label: string;
    match: string[];
  }>;
};
const { recipeService, recipeTiers, recipeSegments } = monetizationConfig;
const terms = getAllTerms();
const termsById = new Map<string, Term>(terms.map((term) => [term.id, term]));

type ResolvedItem = {
  order: number;
  termId: string;
  termName: string;
  category: string;
  durationSec: number;
  duration: "3s" | "5s";
  prompt: string;
};

type ResolvedPack = PromptPack & { resolvedItems: ResolvedItem[] };

const resolved: ResolvedPack[] = packs.map((pack) => ({
  ...pack,
  resolvedItems: pack.items
    .map((item, index): ResolvedItem | null => {
      const term = termsById.get(item.termId);
      if (!term) return null;
      const duration: "3s" | "5s" = item.durationSec >= 5 ? "5s" : "3s";
      const prompt =
        item.promptOverride && item.promptOverride.trim().length > 0
          ? item.promptOverride
          : buildPrompt(term, pack.useCase, duration);
      return {
        order: index + 1,
        termId: term.id,
        termName: term.name,
        category: term.category,
        durationSec: item.durationSec,
        duration,
        prompt,
      };
    })
    .filter((item): item is ResolvedItem => Boolean(item)),
}));

function shotReason(index: number, total: number): string {
  if (index === 0) return "Start by showing where your video happens.";
  if (index === total - 1) return "Finish with a strong detail or emotion.";
  return "Show your main subject in action.";
}

function packTier(index: number): { label: string; tone: string } {
  return (
    recipeTiers.find((tier) => tier.maxPackIndexExclusive === undefined || index < tier.maxPackIndexExclusive) ??
    { label: "Recipe", tone: "#B83A1F" }
  );
}

const quickLinks = [
  { code: "01", label: "Coffee Shop", id: "coffee-shop-reel" },
  { code: "02", label: "Product",     id: "product-macro-hero" },
  { code: "03", label: "Travel",      id: "travel-sunrise-montage" },
  { code: "04", label: "Interview",   id: "interview-broll" },
  { code: "05", label: "Tutorial",    id: "tutorial-talking-head" },
];
---

<BaseLayout
  title="Shot Recipes for AI Videos — aiscreens"
  description="Beginner-friendly shot plans with copyable AI prompts. Pick the kind of video you want to make and get a simple shot recipe."
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="container-pad recipes-hero-grid">
      <div>
        <span class="page-eyebrow">Beginner Friendly · AI-Ready · {resolved.length} Recipes</span>
        <h1 class="page-h1">Shot Recipes for AI Videos</h1>
        <p class="page-subtitle">Pick the kind of video you want to make. We'll give you a simple shot plan with copyable prompts before you spend AI video credits.</p>
      </div>
      <MediaLoop media={siteMedia.recipes.hero} className="recipes-hero-loop" eager />
    </div>
  </section>

  <section style="background:#0F0F13;border-bottom:1px solid rgba(255,255,255,0.08);padding-block:22px;">
    <div class="container-pad recipes-service-strip" style="display:grid;grid-template-columns:1.2fr .8fr;gap:20px;align-items:center;">
      <div>
        <p class="font-ui" style="font-size:12px;font-weight:800;color:#F28A61;letter-spacing:.12em;text-transform:uppercase;margin:0 0 8px;">{recipeService.eyebrow}</p>
        <h2 style="font-family:'Space Grotesk',sans-serif;font-size:clamp(20px,2.5vw,28px);font-weight:900;color:#fff;margin:0 0 6px;">{recipeService.title}</h2>
        <p class="font-ui" style="font-size:14px;line-height:1.6;color:rgba(255,255,255,.52);margin:0;">{recipeService.description}</p>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap;">
        <a href={recipeService.primaryCta.href} class="font-ui focus-ring" style="display:inline-flex;align-items:center;justify-content:center;height:42px;border-radius:999px;background:#B83A1F;color:#fff;text-decoration:none;font-size:14px;font-weight:800;padding:0 18px;">{recipeService.primaryCta.label}</a>
        <a href={recipeService.secondaryCta.href} class="font-ui focus-ring" style="display:inline-flex;align-items:center;justify-content:center;height:42px;border-radius:999px;border:1px solid rgba(255,255,255,.18);color:#fff;text-decoration:none;font-size:14px;font-weight:800;padding:0 18px;">{recipeService.secondaryCta.label}</a>
      </div>
    </div>
  </section>

  <!-- Quick links strip -->
  <section style="background: #fff; border-bottom: 1px solid #E6DDD1; padding-block: 20px;">
    <div class="container-pad">
      <p style="font-family: var(--font-body, 'Inter', sans-serif); font-size: 13px; color: #5F574F; margin: 0 0 12px;">
        Not sure which recipe fits your idea? These are the most popular starting points:
      </p>
      <div class="recipe-quick-links">
        {quickLinks.map((ql) => (
          <a
            href={`#recipe-${ql.id}`}
            class="recipe-quick-link focus-ring"
          ><span>{ql.code}</span>{ql.label}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="recipe-finder-section">
    <div class="container-pad recipe-finder-grid">
      <div>
        <span class="recipe-kicker">Recipe finder</span>
        <h2>Find the closest shot plan before you open a video model.</h2>
        <p>Filter by user goal or search your idea. The page stays simple: pick a recipe, inspect the shot order, then copy prompts or continue in the planner.</p>
      </div>
      <div class="recipe-finder-panel">
        <label>
          <span>Search recipes</span>
          <input type="search" placeholder="product, interview, real estate, tutorial..." data-recipe-search />
        </label>
        <div class="recipe-segment-list">
          <button type="button" class="active" data-recipe-segment="all">All</button>
          {recipeSegments.map((segment) => (
            <button type="button" data-recipe-segment={segment.match.join("|")}>{segment.label}</button>
          ))}
        </div>
        <p data-recipe-count>{resolved.length} recipes visible</p>
      </div>
    </div>
  </section>

  <!-- Recipe cards grid -->
  <section class="page-section page-section-sand">
    <div class="container-pad">
      <div style="display: grid; gap: 24px; grid-template-columns: repeat(auto-fill, minmax(min(100%, 340px), 1fr));">
        <div class="recipe-empty-state" data-recipe-empty hidden>
          <strong>No recipe matched that search.</strong>
          <p>Try a simpler word like product, cafe, interview, travel, tutorial, or use the planner for a custom shot plan.</p>
          <a href="/planner">Open planner →</a>
        </div>
        {resolved.map((pack, packIndex) => (
          <article
            id={`recipe-${pack.id}`}
            data-recipe-card
            data-recipe-text={`${pack.name} ${pack.useCase} ${pack.notes} ${pack.resolvedItems.map((item) => item.termName).join(" ")}`.toLowerCase()}
            style="
              background: #fff;
              border: 1px solid #E6DDD1;
              border-radius: 12px;
              box-shadow: 0 1px 4px rgba(23,23,23,0.06);
              padding: 24px;
              display: flex;
              flex-direction: column;
              gap: 12px;
              transition: transform 0.15s, box-shadow 0.15s;
            "
            onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 6px 20px rgba(23,23,23,0.10)';"
            onmouseout="this.style.transform=''; this.style.boxShadow='0 1px 4px rgba(23,23,23,0.06)';"
          >
            <!-- Use-case tag -->
            <div>
              <span style={`
                display:inline-block;
                background:${packTier(packIndex).tone}18;
                color:${packTier(packIndex).tone};
                font-family:var(--font-ui,sans-serif);
                font-size:10px;
                font-weight:800;
                letter-spacing:.08em;
                text-transform:uppercase;
                padding:3px 9px;
                border-radius:999px;
                margin-right:6px;
              `}>{packTier(packIndex).label}</span>
              <span style="
                display: inline-block;
                background: rgba(184,58,31,0.1);
                color: #B83A1F;
                font-family: var(--font-ui, sans-serif);
                font-size: 11px;
                font-weight: 700;
                letter-spacing: 0.06em;
                text-transform: uppercase;
                padding: 3px 10px;
                border-radius: 999px;
              ">{pack.useCase.split(" ").slice(0, 4).join(" ")}</span>
            </div>

            <!-- Pack name -->
            <h2 style="
              font-family: var(--font-display, 'Space Grotesk', sans-serif);
              font-size: 20px;
              font-weight: 700;
              color: var(--color-ink, #171717);
              margin: 0;
              line-height: 1.2;
            ">{pack.name}</h2>

            <!-- Description -->
            <p style="
              font-family: var(--font-body, 'Inter', sans-serif);
              font-size: 14px;
              line-height: 1.5;
              color: rgba(23,23,23,0.64);
              margin: 0;
            ">{pack.useCase}</p>

            <!-- Stats row -->
            <div style="display: flex; flex-wrap: wrap; gap: 6px;">
              <span style="
                background: #F2ECE4;
                color: rgba(23,23,23,0.62);
                font-family: var(--font-ui, sans-serif);
                font-size: 12px;
                font-weight: 600;
                padding: 3px 10px;
                border-radius: 999px;
              ">{pack.items.length} shots</span>
              <span style="
                background: #F2ECE4;
                color: rgba(23,23,23,0.62);
                font-family: var(--font-ui, sans-serif);
                font-size: 12px;
                font-weight: 600;
                padding: 3px 10px;
                border-radius: 999px;
              ">Beginner friendly</span>
            </div>

            <!-- Action buttons -->
            <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px;">
              <button
                type="button"
                class="recipe-open-btn"
                data-pack-id={pack.id}
                style="
                  background: #B83A1F;
                  color: #fff;
                  border: none;
                  border-radius: 999px;
                  height: 36px;
                  padding: 0 16px;
                  font-family: var(--font-ui, sans-serif);
                  font-size: 13px;
                  font-weight: 700;
                  cursor: pointer;
                  transition: background 0.12s;
                "
                onmouseover="this.style.background='#962d17'"
                onmouseout="this.style.background='#B83A1F'"
              >Open Recipe</button>
              <button
                type="button"
                class="recipe-copy-all-btn"
                data-pack-id={pack.id}
                style="
                  background: transparent;
                  color: #171717;
                  border: 1px solid #D8CFC3;
                  border-radius: 999px;
                  height: 36px;
                  padding: 0 16px;
                  font-family: var(--font-ui, sans-serif);
                  font-size: 13px;
                  font-weight: 700;
                  cursor: pointer;
                  transition: background 0.12s;
                "
                onmouseover="this.style.background='rgba(23,23,23,0.05)'"
                onmouseout="this.style.background='transparent'"
              >Copy All Prompts</button>
              <a
                href={`/planner?topic=${encodeURIComponent(pack.name)}`}
                style="
                  display: inline-flex;
                  align-items: center;
                  height: 36px;
                  padding: 0 12px;
                  font-family: var(--font-ui, sans-serif);
                  font-size: 13px;
                  font-weight: 700;
                  color: #5F574F;
                  text-decoration: none;
                  transition: color 0.12s;
                "
                onmouseover="this.style.color='#B83A1F'"
                onmouseout="this.style.color='#5F574F'"
              >→ Planner</a>
            </div>

            <!-- Expandable detail section -->
            <div
              id={`detail-${pack.id}`}
              data-detail
              style="
                max-height: 0;
                overflow: hidden;
                transition: max-height 0.4s cubic-bezier(0.4,0,0.2,1);
              "
            >
              <div style="padding-top: 16px; border-top: 1px solid #E6DDD1; margin-top: 8px;">
                <!-- Shot timeline -->
                <ol style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px;">
                  {pack.resolvedItems.map((item, idx) => (
                    <li style="display: flex; gap: 12px; align-items: flex-start;">
                      <!-- Number badge -->
                      <span style="
                        flex-shrink: 0;
                        width: 28px;
                        height: 28px;
                        border-radius: 50%;
                        background: #B83A1F;
                        color: #fff;
                        display: grid;
                        place-items: center;
                        font-family: var(--font-ui, sans-serif);
                        font-size: 12px;
                        font-weight: 700;
                        margin-top: 2px;
                      ">{item.order}</span>
                      <div style="flex: 1; min-width: 0;">
                        <!-- Shot name + duration -->
                        <div style="display: flex; align-items: center; justify-content: space-between; gap: 8px; flex-wrap: wrap; margin-bottom: 4px;">
                          <span style="
                            font-family: var(--font-ui, sans-serif);
                            font-size: 14px;
                            font-weight: 700;
                            color: #171717;
                          ">{item.termName}</span>
                          <span style="
                            background: #F2ECE4;
                            color: rgba(23,23,23,0.55);
                            font-family: var(--font-ui, sans-serif);
                            font-size: 11px;
                            font-weight: 600;
                            padding: 2px 8px;
                            border-radius: 999px;
                          ">{item.durationSec}s</span>
                        </div>
                        <!-- Reason -->
                        <p style="
                          font-family: var(--font-body, 'Inter', sans-serif);
                          font-size: 12px;
                          color: rgba(23,23,23,0.56);
                          margin: 0 0 8px;
                          line-height: 1.4;
                        ">{shotReason(idx, pack.resolvedItems.length)}</p>
                        <!-- Dark prompt block -->
                        <div style="position: relative;">
                          <pre style="
                            background: #101014;
                            color: rgba(248,245,239,0.88);
                            font-family: var(--font-mono, 'JetBrains Mono', monospace);
                            font-size: 12px;
                            line-height: 1.5;
                            padding: 10px 12px;
                            padding-right: 64px;
                            border-radius: 8px;
                            margin: 0;
                            white-space: pre-wrap;
                            word-break: break-word;
                          ">{item.prompt}</pre>
                          <button
                            type="button"
                            class="recipe-copy-single-btn"
                            data-prompt={item.prompt}
                            style="
                              position: absolute;
                              top: 8px;
                              right: 8px;
                              background: rgba(255,255,255,0.1);
                              color: rgba(248,245,239,0.7);
                              border: none;
                              border-radius: 6px;
                              padding: 4px 8px;
                              font-family: var(--font-ui, sans-serif);
                              font-size: 11px;
                              font-weight: 600;
                              cursor: pointer;
                              transition: background 0.12s;
                            "
                            onmouseover="this.style.background='rgba(255,255,255,0.2)'"
                            onmouseout="this.style.background='rgba(255,255,255,0.1)'"
                          >Copy</button>
                        </div>
                      </div>
                    </li>
                  ))}
                </ol>

                <!-- Copy all (full width) -->
                <button
                  type="button"
                  class="recipe-copy-all-btn"
                  data-pack-id={pack.id}
                  style="
                    display: block;
                    width: 100%;
                    margin-top: 20px;
                    background: #B83A1F;
                    color: #fff;
                    border: none;
                    border-radius: 999px;
                    height: 44px;
                    font-family: var(--font-ui, sans-serif);
                    font-size: 14px;
                    font-weight: 700;
                    cursor: pointer;
                    transition: background 0.12s;
                  "
                  onmouseover="this.style.background='#962d17'"
                  onmouseout="this.style.background='#B83A1F'"
                >Copy All Prompts</button>

                <!-- Try in planner -->
                <a
                  href={`/planner?topic=${encodeURIComponent(pack.name)}`}
                  style="
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    margin-top: 10px;
                    height: 40px;
                    font-family: var(--font-ui, sans-serif);
                    font-size: 13px;
                    font-weight: 700;
                    color: #B83A1F;
                    text-decoration: none;
                    gap: 4px;
                  "
                  onmouseover="this.style.textDecoration='underline'"
                  onmouseout="this.style.textDecoration='none'"
                >Try in Planner →</a>

                <!-- Director tip -->
                {pack.notes && (
                  <p style="
                    margin-top: 14px;
                    background: #F8F5EF;
                    border-left: 3px solid #B83A1F;
                    padding: 10px 14px;
                    border-radius: 0 8px 8px 0;
                    font-family: var(--font-body, 'Inter', sans-serif);
                    font-size: 13px;
                    line-height: 1.5;
                    color: rgba(23,23,23,0.7);
                    margin-bottom: 0;
                  ">
                    <strong style="color: #B83A1F; font-weight: 700;">Tip from a director:</strong> {pack.notes}
                  </p>
                )}

                <!-- Close button -->
                <button
                  type="button"
                  class="recipe-close-btn"
                  data-pack-id={pack.id}
                  style="
                    display: block;
                    width: 100%;
                    margin-top: 16px;
                    background: transparent;
                    color: rgba(23,23,23,0.45);
                    border: 1px solid #D8CFC3;
                    border-radius: 999px;
                    height: 36px;
                    font-family: var(--font-ui, sans-serif);
                    font-size: 13px;
                    font-weight: 600;
                    cursor: pointer;
                    transition: background 0.12s;
                  "
                  onmouseover="this.style.background='rgba(23,23,23,0.04)'"
                  onmouseout="this.style.background='transparent'"
                >Close ✕</button>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- All prompts data for copy-all (hidden) -->
  <script is:inline define:vars={{ packPrompts: resolved.map(p => ({ id: p.id, prompts: p.resolvedItems.map(i => i.prompt) })) }}>
    var activeSegment = "all";
    var searchInput = document.querySelector("[data-recipe-search]");
    var count = document.querySelector("[data-recipe-count]");
    var empty = document.querySelector("[data-recipe-empty]");
    var cards = Array.prototype.slice.call(document.querySelectorAll("[data-recipe-card]"));

    function updateRecipeFilters() {
      var query = (searchInput && searchInput.value ? searchInput.value : "").toLowerCase().trim();
      var tokens = activeSegment === "all" ? [] : activeSegment.split("|").map(function(token) { return token.toLowerCase().trim(); }).filter(Boolean);
      var visible = 0;
      cards.forEach(function(card) {
        var text = card.getAttribute("data-recipe-text") || "";
        var matchesQuery = !query || text.indexOf(query) !== -1;
        var matchesSegment = tokens.length === 0 || tokens.some(function(token) { return text.indexOf(token) !== -1; });
        var show = matchesQuery && matchesSegment;
        card.style.display = show ? "" : "none";
        if (show) visible += 1;
      });
      if (count) count.textContent = visible + (visible === 1 ? " recipe visible" : " recipes visible");
      if (empty) empty.hidden = visible !== 0;
    }

    document.querySelectorAll("[data-recipe-segment]").forEach(function(button) {
      button.addEventListener("click", function() {
        activeSegment = button.getAttribute("data-recipe-segment") || "all";
        document.querySelectorAll("[data-recipe-segment]").forEach(function(item) { item.classList.remove("active"); });
        button.classList.add("active");
        updateRecipeFilters();
      });
    });

    if (searchInput) {
      searchInput.addEventListener("input", updateRecipeFilters);
    }

    updateRecipeFilters();

    // Open / Close recipe details
    document.querySelectorAll(".recipe-open-btn").forEach(function(btn) {
      btn.addEventListener("click", function() {
        var packId = btn.getAttribute("data-pack-id");
        var detail = document.getElementById("detail-" + packId);
        if (!detail) return;
        // expand
        detail.style.maxHeight = detail.scrollHeight + 500 + "px";
        btn.style.display = "none";
      });
    });

    document.querySelectorAll(".recipe-close-btn").forEach(function(btn) {
      btn.addEventListener("click", function() {
        var packId = btn.getAttribute("data-pack-id");
        var detail = document.getElementById("detail-" + packId);
        if (!detail) return;
        detail.style.maxHeight = "0";
        // show open button again
        var openBtn = document.querySelector(".recipe-open-btn[data-pack-id='" + packId + "']");
        if (openBtn) openBtn.style.display = "";
      });
    });

    // Copy single prompt
    document.querySelectorAll(".recipe-copy-single-btn").forEach(function(btn) {
      btn.addEventListener("click", async function() {
        var prompt = btn.getAttribute("data-prompt") || "";
        try {
          await navigator.clipboard.writeText(prompt);
          var orig = btn.textContent;
          btn.textContent = "Copied!";
          setTimeout(function() { btn.textContent = orig; }, 1200);
        } catch(e) {}
      });
    });

    // Copy all prompts
    document.querySelectorAll(".recipe-copy-all-btn").forEach(function(btn) {
      btn.addEventListener("click", async function() {
        var packId = btn.getAttribute("data-pack-id");
        var pack = packPrompts.find(function(p) { return p.id === packId; });
        if (!pack) return;
        var text = pack.prompts.join("\n\n");
        try {
          await navigator.clipboard.writeText(text);
          var orig = btn.textContent;
          btn.textContent = "Copied!";
          setTimeout(function() { btn.textContent = orig; }, 1200);
        } catch(e) {}
      });
    });
  </script>
</BaseLayout>

<style>
  .recipes-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.86fr) minmax(380px, 0.86fr);
    gap: clamp(22px, 5vw, 60px);
    align-items: center;
  }

  .recipes-hero-grid :global(.recipes-hero-loop) {
    border: 1px solid #E6DDD1;
    border-radius: 24px;
    box-shadow: 0 24px 74px rgba(23,23,23,0.12);
  }

  .recipe-quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .recipe-quick-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 36px;
    padding: 0 14px 0 8px;
    border-radius: 999px;
    border: 1px solid #E6DDD1;
    background: #F8F5EF;
    color: #171717;
    font-family: var(--font-ui, sans-serif);
    font-size: 13px;
    font-weight: 800;
    text-decoration: none;
    transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }

  .recipe-quick-link span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 999px;
    background: #171717;
    color: #F8F5EF;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.04em;
  }

  .recipe-quick-link:hover {
    border-color: #B83A1F;
    background: rgba(184,58,31,0.08);
