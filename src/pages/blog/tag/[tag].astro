---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const tagMap = new Map<string, typeof allPosts>();
  for (const post of allPosts) {
    for (const tag of post.data.tags) {
      if (!tagMap.has(tag)) tagMap.set(tag, []);
      tagMap.get(tag)!.push(post);
    }
  }
  return [...tagMap.entries()].map(([tag, posts]) => ({
    params: { tag },
    props: { posts: posts.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()) },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;

const categoryColors: Record<string, string> = {
  shots:          "#E4572E",
  lighting:       "#F59E0B",
  movement:       "#8B5CF6",
  editing:        "#10B981",
  "ai-prompting": "#3B82F6",
};

function formatDate(d: Date) {
  return d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}
---

<BaseLayout
  title={`#${tag} — Blog | aiscreens`}
  description={`All aiscreens blog posts tagged with "${tag}". Learn cinematography, lighting, camera movement, and AI video prompting.`}
>
  <!-- Hero -->
  <section style="background: #0F0F13; padding-block: clamp(48px, 6vw, 80px);">
    <div class="container-pad">
      <nav style="display: flex; align-items: center; gap: 8px; margin-bottom: 28px;" aria-label="Breadcrumb">
        <a href="/" class="font-ui" style="font-size: 12px; color: rgba(255,255,255,0.3); text-decoration: none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">Home</a>
        <span style="color: rgba(255,255,255,0.2); font-size: 12px;">›</span>
        <a href="/blog" class="font-ui" style="font-size: 12px; color: rgba(255,255,255,0.3); text-decoration: none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">Blog</a>
        <span style="color: rgba(255,255,255,0.2); font-size: 12px;">›</span>
        <span class="font-ui" style="font-size: 12px; color: rgba(255,255,255,0.5);">#{tag}</span>
      </nav>

      <div style="margin-bottom: 16px;">
        <span class="font-ui" style="display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); color: rgba(255,255,255,0.7); font-size: 13px; font-weight: 600; padding: 6px 16px; border-radius: 999px;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          #{tag}
        </span>
      </div>
      <h1 style="font-family: 'Space Grotesk', sans-serif; font-size: clamp(26px, 4vw, 44px); font-weight: 700; color: #fff; line-height: 1.1; letter-spacing: -0.025em; margin: 0 0 12px;">
        Posts tagged <span style="color: rgba(255,255,255,0.4);">"{tag}"</span>
      </h1>
      <p class="font-ui" style="font-size: 14px; color: rgba(255,255,255,0.3); margin: 0;">
        {posts.length} article{posts.length !== 1 ? "s" : ""}
      </p>
    </div>
  </section>

  <!-- Posts -->
  <div style="background: #F8F5EF; min-height: 60vh;">
    <div class="container-pad" style="padding-block: clamp(40px, 5vw, 64px);">
      <div class="tag-grid">
        {posts.map(post => (
          <a
            href={`/blog/${post.slug}`}
            style="display: flex; flex-direction: column; text-decoration: none; border-radius: 16px; overflow: hidden; background: #fff; border: 1px solid #E6DDD1; transition: transform 0.18s, box-shadow 0.18s;"
            onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 16px 48px rgba(0,0,0,0.1)'"
            onmouseout="this.style.transform=''; this.style.boxShadow=''"
          >
            <div style={`height: 5px; background: ${categoryColors[post.data.category] ?? '#E4572E'};`}></div>
            <div style="padding: 22px 24px; display: flex; flex-direction: column; flex: 1;">
              <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px;">
                <span style={`font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 700; color: ${categoryColors[post.data.category] ?? '#E4572E'}; background: ${categoryColors[post.data.category] ?? '#E4572E'}18; border-radius: 4px; padding: 2px 8px; letter-spacing: 0.06em; text-transform: uppercase;`}>
                  {post.data.category.replace("-", " ")}
                </span>
              </div>
              <h2 style="font-family: 'Space Grotesk', sans-serif; font-size: 17px; font-weight: 700; color: #171717; line-height: 1.3; letter-spacing: -0.01em; margin: 0 0 10px; flex: 1;">
                {post.data.title}
              </h2>
              <p class="font-ui" style="font-size: 13px; color: #7A7268; line-height: 1.6; margin: 0 0 16px;">
                {post.data.description}
              </p>
              <!-- Tags -->
              <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px;">
                {post.data.tags.map(t => (
                  <span
                    class="font-ui"
                    style={`font-size: 10px; font-weight: 600; color: ${t === tag ? '#E4572E' : '#7A7268'}; background: ${t === tag ? 'rgba(228,87,46,0.08)' : '#F0EBE3'}; border-radius: 4px; padding: 2px 8px;`}
                  >#{t}</span>
                ))}
              </div>
              <div style="display: flex; align-items: center; justify-content: space-between; padding-top: 14px; border-top: 1px solid #F0EBE3;">
                <span class="font-ui" style="font-size: 11px; color: #7A7268;">{formatDate(post.data.publishedAt)}</span>
                <span style="font-size: 13px; color: #E4572E; font-weight: 700;">Read →</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div style="margin-top: 40px; text-align: center;">
        <a href="/blog" class="font-ui" style="display: inline-flex; align-items: center; gap: 8px; color: #4F4A45; font-size: 14px; font-weight: 600; text-decoration: none; border: 1.5px solid #E6DDD1; border-radius: 999px; padding: 10px 24px; transition: all 0.15s;" onmouseover="this.style.borderColor='#C4B8AC'" onmouseout="this.style.borderColor='#E6DDD1'">
          ← All posts
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .tag-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 900px) { .tag-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .tag-grid { grid-template-columns: 1fr; } }
</style>
