---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const categories = [...new Set(allPosts.map(p => p.data.category))];
  return categories.map(category => ({
    params: { category },
    props: { posts: allPosts.filter(p => p.data.category === category).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()) },
  }));
}

const { category } = Astro.params;
const { posts } = Astro.props;

const categoryColors: Record<string, string> = {
  shots:          "#E4572E",
  lighting:       "#F59E0B",
  movement:       "#8B5CF6",
  editing:        "#10B981",
  "ai-prompting": "#3B82F6",
};

const categoryMeta: Record<string, { headline: string; description: string; visualLabel: string; visualSteps: string[] }> = {
  shots: {
    headline: "Shot Types & Framing",
    description: "Master wide shots, close-ups, and everything in between — then write them into your AI video prompts.",
    visualLabel: "Frame plan",
    visualSteps: ["Wide", "Medium", "Close"],
  },
  lighting: {
    headline: "Lighting for Video & AI",
    description: "Golden hour, Rembrandt, neon practicals — learn the language of light and how to describe it in prompts.",
    visualLabel: "Light map",
    visualSteps: ["Key", "Fill", "Rim"],
  },
  movement: {
    headline: "Camera Movement",
    description: "Dolly, pan, tilt, handheld — every movement carries emotion. Learn what each does and how to specify it.",
    visualLabel: "Motion path",
    visualSteps: ["Start", "Move", "Land"],
  },
  editing: {
    headline: "Editing Techniques",
    description: "Cut, dissolve, match cut — understand how editing shapes rhythm, time, and meaning.",
    visualLabel: "Timeline",
    visualSteps: ["Shot A", "Cut", "Shot B"],
  },
  "ai-prompting": {
    headline: "AI Video Prompting",
    description: "Frameworks, vocabulary, and techniques for writing prompts that produce cinematic results in Runway, Pika, and Stable Video.",
    visualLabel: "Prompt stack",
    visualSteps: ["Subject", "Motion", "Light"],
  },
};

const meta = categoryMeta[category] ?? {
  headline: category,
  description: "",
  visualLabel: "Video note",
  visualSteps: ["Learn", "Plan", "Prompt"],
};
const color = categoryColors[category] ?? "#E4572E";
const label = category.replace("-", " ");

function formatDate(d: Date) {
  return d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}
---

<BaseLayout
  title={`${meta.headline} — Blog | aiscreens`}
  description={meta.description}
>
  <!-- Hero -->
  <section style="background: #0F0F13; padding-block: clamp(48px, 6vw, 80px);">
    <div class="container-pad">
      <nav style="display: flex; align-items: center; gap: 8px; margin-bottom: 28px;" aria-label="Breadcrumb">
        <a href="/" class="font-ui" style="font-size: 12px; color: rgba(255,255,255,0.3); text-decoration: none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">Home</a>
        <span style="color: rgba(255,255,255,0.2); font-size: 12px;">›</span>
        <a href="/blog" class="font-ui" style="font-size: 12px; color: rgba(255,255,255,0.3); text-decoration: none;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">Blog</a>
        <span style="color: rgba(255,255,255,0.2); font-size: 12px;">›</span>
        <span class="font-ui" style={`font-size: 12px; color: ${color}; text-transform: capitalize;`}>{label}</span>
      </nav>

      <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 20px;">
        <div class="category-visual" style={`--category-color:${color};`} aria-hidden="true">
          <span>{meta.visualLabel}</span>
          <div>
            {meta.visualSteps.map((step) => <em>{step}</em>)}
          </div>
        </div>
        <div>
          <span class="font-ui" style={`display: inline-block; font-size: 10px; font-weight: 700; color: ${color}; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 8px;`}>{posts.length} article{posts.length !== 1 ? "s" : ""}</span>
          <h1 style="font-family: 'Space Grotesk', sans-serif; font-size: clamp(26px, 4vw, 44px); font-weight: 700; color: #fff; line-height: 1.1; letter-spacing: -0.025em; margin: 0;">
            {meta.headline}
          </h1>
        </div>
      </div>
      <p class="font-ui" style="font-size: 16px; color: rgba(255,255,255,0.45); line-height: 1.65; max-width: 560px; margin: 0;">
        {meta.description}
      </p>
    </div>
  </section>

  <!-- All categories strip -->
  <div style="background: #0F0F13; border-bottom: 1px solid rgba(255,255,255,0.07);">
    <div class="container-pad">
      <div style="display: flex; gap: 4px; overflow-x: auto; padding-block: 12px; scrollbar-width: none;">
        <a href="/blog" class="font-ui" style="flex-shrink: 0; font-size: 13px; font-weight: 600; padding: 7px 16px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.12); color: rgba(255,255,255,0.45); text-decoration: none; transition: all 0.15s;" onmouseover="this.style.color='#fff';this.style.borderColor='rgba(255,255,255,0.3)'" onmouseout="this.style.color='rgba(255,255,255,0.45)';this.style.borderColor='rgba(255,255,255,0.12)'">All Posts</a>
        {(["shots","lighting","movement","editing","ai-prompting"] as const).map(cat => (
          <a
            href={`/blog/category/${cat}`}
            class="font-ui"
            style={`flex-shrink: 0; font-size: 13px; font-weight: 600; padding: 7px 16px; border-radius: 999px; border: 1px solid ${cat === category ? `${categoryColors[cat]}60` : 'transparent'}; color: ${cat === category ? '#fff' : 'rgba(255,255,255,0.4)'}; background: ${cat === category ? `${categoryColors[cat]}20` : 'transparent'}; text-decoration: none; text-transform: capitalize; transition: all 0.15s;`}
            onmouseover={`this.style.color='#fff'`}
            onmouseout={cat !== category ? `this.style.color='rgba(255,255,255,0.4)'` : ""}
          >{cat.replace("-", " ")}</a>
        ))}
      </div>
    </div>
  </div>

  <!-- Posts grid -->
  <div style="background: #F8F5EF; min-height: 60vh;">
    <div class="container-pad" style="padding-block: clamp(40px, 5vw, 64px);">
      {posts.length === 0 ? (
        <p class="font-ui" style="text-align: center; color: #7A7268; padding: 80px 0;">No posts yet in this category — check back soon.</p>
      ) : (
        <div class="cat-grid">
          {posts.map(post => (
            <a
              href={`/blog/${post.slug}`}
              style="display: flex; flex-direction: column; text-decoration: none; border-radius: 16px; overflow: hidden; background: #fff; border: 1px solid #E6DDD1; transition: transform 0.18s, box-shadow 0.18s;"
              onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 16px 48px rgba(0,0,0,0.1)'"
              onmouseout="this.style.transform=''; this.style.boxShadow=''"
            >
              <div style={`height: 5px; background: ${color};`}></div>
              <div style="padding: 22px 24px; display: flex; flex-direction: column; flex: 1;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 12px;">
                  <span class="font-ui" style={`font-size: 10px; font-weight: 700; color: ${color}; text-transform: uppercase; letter-spacing: 0.06em;`}>{label}</span>
                  <span class="font-ui" style="font-size: 10px; color: #7A7268; text-transform: uppercase; letter-spacing: 0.06em;">{post.data.difficulty}</span>
                </div>
                <h2 style="font-family: 'Space Grotesk', sans-serif; font-size: 17px; font-weight: 700; color: #171717; line-height: 1.3; letter-spacing: -0.01em; margin: 0 0 10px; flex: 1;">
                  {post.data.title}
                </h2>
                <p class="font-ui" style="font-size: 13px; color: #7A7268; line-height: 1.6; margin: 0 0 20px;">
                  {post.data.description}
                </p>
                <div style="display: flex; align-items: center; justify-content: space-between; padding-top: 14px; border-top: 1px solid #F0EBE3;">
                  <span class="font-ui" style="font-size: 11px; color: #7A7268;">{formatDate(post.data.publishedAt)}</span>
                  <div style="display: flex; align-items: center; gap: 4px;">
                    {post.data.readingTime && <span class="font-ui" style="font-size: 11px; color: #7A7268;">{post.data.readingTime} min</span>}
                    <span style="font-size: 13px; color: #E4572E; font-weight: 700; margin-left: 4px;">→</span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .category-visual {
    width: 148px;
    min-height: 92px;
    display: grid;
    align-content: center;
    gap: 12px;
    flex: 0 0 auto;
    padding: 14px;
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.14);
    background:
      linear-gradient(90deg, rgba(255,255,255,0.14) 1px, transparent 1px) 14px 12px / 22px 10px repeat-x,
      radial-gradient(circle at 74% 26%, color-mix(in srgb, var(--category-color) 44%, transparent), transparent 32%),
      linear-gradient(135deg, #171720, #2A2830 58%, color-mix(in srgb, var(--category-color) 56%, #171720));
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.06), 0 18px 54px rgba(0,0,0,0.2);
  }

  .category-visual span {
    width: fit-content;
    padding: 6px 9px;
    border-radius: 999px;
    background: rgba(15,15,19,0.74);
    color: rgba(255,255,255,0.78);
    font-family: var(--font-ui, Inter, sans-serif);
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .category-visual div {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 6px;
  }

  .category-visual em {
    min-width: 0;
    padding: 6px 5px;
    border-radius: 10px;
    background: rgba(255,244,225,0.9);
    color: #171717;
    font-family: var(--font-ui, Inter, sans-serif);
    font-size: 9px;
    font-style: normal;
    font-weight: 900;
    letter-spacing: 0.04em;
    overflow: hidden;
    text-align: center;
    text-overflow: ellipsis;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 900px) { .cat-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) {
    .cat-grid { grid-template-columns: 1fr; }
    .category-visual { width: 112px; min-height: 82px; padding: 12px; }
    .category-visual div { grid-template-columns: 1fr; }
    .category-visual em { padding-block: 4px; }
  }
</style>
