---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import GlossaryGrid from "../../../../components/GlossaryGrid.astro";
import { getAllTerms } from "../../../../lib/termSearch";
import { LOCALES, DEFAULT_LOCALE, getLocalisedTerm, getUiStrings, type Locale } from "../../../i18n";

export async function getStaticPaths() {
  return LOCALES.filter((l) => l !== DEFAULT_LOCALE).map((lang) => ({
    params: { lang },
    props: { lang }
  }));
}

interface Props {
  lang: Locale;
}

const { lang } = Astro.props as Props;
const t = getUiStrings(lang);
const terms = getAllTerms().map((term) => getLocalisedTerm(term, lang));
---

<BaseLayout
  lang={lang}
  title="CineCards AI Glossary - Film terms for shooting and AI video prompts"
  description="Search cinematography, videography, editing, lighting, composition, lens, and AI workflow terms as copyable visual cards."
>
  <section class="bg-paper py-14">
    <div class="container-pad">
      <p class="eyebrow text-clay">{t.glossary.eyebrow}</p>
      <h1 class="mt-3 max-w-3xl text-4xl font-black tracking-tight text-ink sm:text-5xl">{t.glossary.title}</h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-ink/68">
        {t.glossary.subtitle}
      </p>
    </div>
  </section>
  <section class="pb-16">
    <div class="container-pad">
      <GlossaryGrid terms={terms} />
    </div>
  </section>
</BaseLayout>
