---
import "../../src/styles/global.css";
import Header from "../../components/Header.astro";
import { seo } from "../site.config";

import type { Locale } from "../i18n";

interface Props {
  title?: string;
  description?: string;
  lang?: Locale;
}

const {
  title = seo.defaultTitle,
  description = seo.defaultDescription,
  lang = "en"
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/cinecards-hero.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content={seo.themeColor} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <slot name="head" />
  </head>
  <body class="font-ui antialiased">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header lang={lang} />
    <main id="main-content">
      <slot />
    </main>
    <footer style="background: var(--bg-dark, #101014); border-top: 1px solid rgba(255,255,255,0.08); padding-block: 40px; color: #F8F5EF;">
      <div class="container-pad" style="display: flex; flex-direction: column; gap: 16px;">
        <div style="display: flex; flex-direction: column; gap: 16px; justify-content: space-between; align-items: flex-start;">
          <p class="font-ui" style="font-size: 14px; color: rgba(248,245,239,0.65); margin: 0;">
            <strong style="color: #F8F5EF; font-weight: 700;">CineCards AI</strong> — open-source visual grammar for human and AI video creation.
          </p>
          <div style="display: flex; gap: 20px; flex-wrap: wrap;">
            <a class="font-ui focus-ring" style="font-size: 14px; color: rgba(248,245,239,0.55); text-decoration: none; transition: color 0.15s;" href="/glossary"
              onmouseover="this.style.color='#F8F5EF'" onmouseout="this.style.color='rgba(248,245,239,0.55)'">Glossary</a>
            <a class="font-ui focus-ring" style="font-size: 14px; color: rgba(248,245,239,0.55); text-decoration: none; transition: color 0.15s;" href="/planner"
              onmouseover="this.style.color='#F8F5EF'" onmouseout="this.style.color='rgba(248,245,239,0.55)'">Planner</a>
            <a class="font-ui focus-ring" style="font-size: 14px; color: rgba(248,245,239,0.55); text-decoration: none; transition: color 0.15s;" href="/#contribute"
              onmouseover="this.style.color='#F8F5EF'" onmouseout="this.style.color='rgba(248,245,239,0.55)'">Contribute</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
