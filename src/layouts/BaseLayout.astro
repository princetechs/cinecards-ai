---
import "../../src/styles/global.css";
import Header from "../../components/Header.astro";

import type { Locale } from "../i18n";

interface Props {
  title?: string;
  description?: string;
  lang?: Locale;
}

const {
  title = "CineCards AI - Visual film terms and AI video shot planning",
  description = "A lightweight open-source learning tool for cinematography, videography, and AI video prompts.",
  lang = "en"
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/cinecards-hero.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#f5f0e8" />
    <slot name="head" />
  </head>
  <body class="font-body antialiased">
    <Header lang={lang} />
    <main>
      <slot />
    </main>
    <footer class="border-t border-ink/10 bg-night py-10 text-bone">
      <div class="container-pad flex flex-col gap-4 text-sm text-bone/70 sm:flex-row sm:items-center sm:justify-between">
        <p><strong class="text-bone">CineCards AI</strong> is open-source visual grammar for human and AI video creation.</p>
        <div class="flex gap-4">
          <a class="hover:text-bone" href="/glossary">Glossary</a>
          <a class="hover:text-bone" href="/planner">Planner</a>
          <a class="hover:text-bone" href="/#contribute">Contribute</a>
        </div>
      </div>
    </footer>
  </body>
</html>
