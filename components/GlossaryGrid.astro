---
import type { Term } from "../types/term";
import TermCard from "./TermCard.astro";
import SearchFilters from "./SearchFilters.astro";

interface Props {
  terms: Term[];
  showFilters?: boolean;
}

const { terms, showFilters = true } = Astro.props;
const categories = Array.from(new Set(terms.map((t) => t.category))).sort();
const priorityGroups = Array.from(new Set(terms.map((t) => t.priorityGroup)));
const difficulties = Array.from(new Set(terms.map((t) => t.difficulty))).sort();
---

<div data-glossary-root>
  {showFilters && (
    <SearchFilters
      categories={categories}
      priorityGroups={priorityGroups}
      difficulties={difficulties}
    />
  )}

  <!-- Stats bar -->
  <p class="stats-bar" data-filter-count>Showing {terms.length} of {terms.length} terms</p>

  <!-- Grid -->
  <div class="glossary-grid" data-glossary-grid>
    {terms.map((term) => <TermCard term={term} />)}
  </div>

  <!-- Empty state -->
  <div class="empty-state hidden" data-empty-state>
    <div class="empty-inner">
      <p class="empty-icon">🎬</p>
      <p class="empty-heading">No matching terms</p>
      <p class="empty-sub">Try searching "camera movement," "close-up," or "lighting."</p>
      <button class="empty-reset" type="button" data-reset-filters>Reset filters</button>
    </div>
  </div>
</div>

<style>
  .stats-bar {
    font-family: var(--font-ui, Inter, sans-serif);
    font-size: 13px;
    color: #7A7268;
    margin: 16px 0 20px;
  }
  .glossary-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 768px) {
    .glossary-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1280px) {
    .glossary-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* Empty state */
  .empty-state { margin-top: 48px; }
  .empty-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 48px 24px;
    background: #fff;
    border: 1px solid #E6DDD1;
    border-radius: 20px;
    text-align: center;
  }
  .empty-icon { font-size: 2.5rem; margin: 0; }
  .empty-heading {
    font-family: "Space Grotesk", var(--font-display, sans-serif);
    font-size: 1.25rem; font-weight: 700; color: #171717; margin: 0;
  }
  .empty-sub {
    font-family: var(--font-body, Inter, sans-serif);
    font-size: 15px; color: #7A7268; margin: 0; max-width: 36ch;
  }
  .empty-reset {
    font-family: var(--font-ui, Inter, sans-serif);
    font-size: 13px; font-weight: 600;
    background: #E4572E; color: #fff;
    border: none; border-radius: 999px;
    padding: 8px 20px; cursor: pointer;
    transition: background 150ms;
    margin-top: 4px;
  }
  .empty-reset:hover { background: #B83A1F; }
</style>

<script>
  import { track } from "../lib/analytics";

  const applyGlossaryFilters = (root: HTMLElement) => {
    const search = root.querySelector<HTMLInputElement>("[data-filter-search]")?.value.toLowerCase().trim() ?? "";
    const category = root.querySelector<HTMLSelectElement>("[data-filter-category]")?.value ?? "";
    const priority = root.querySelector<HTMLSelectElement>("[data-filter-priority]")?.value ?? "";
    const difficulty = root.querySelector<HTMLSelectElement>("[data-filter-difficulty]")?.value ?? "";

    const cards = Array.from(root.querySelectorAll<HTMLElement>("[data-term-card]"));
    let visible = 0;

    cards.forEach((card) => {
      // Respect beginner-path override
      if (card.hasAttribute("data-beginner-hidden")) return;
      const matchSearch = !search || (card.dataset.search ?? "").includes(search);
      const matchCat = !category || card.dataset.category === category;
      const matchPri = !priority || card.dataset.priority === priority;
      const matchDiff = !difficulty || card.dataset.difficulty === difficulty;
      const show = matchSearch && matchCat && matchPri && matchDiff;
      card.classList.toggle("hidden", !show);
      if (show) visible += 1;
    });

    // Count also non-hidden beginner-path cards
    visible = cards.filter((c) => !c.classList.contains("hidden") && !c.hasAttribute("data-beginner-hidden")).length;

    const count = root.querySelector<HTMLElement>("[data-filter-count]");
    if (count) count.textContent = `Showing ${visible} of ${cards.length} terms`;

    root.querySelector<HTMLElement>("[data-empty-state]")?.classList.toggle("hidden", visible !== 0);

    if (search) track("search_performed", { query: search, resultCount: visible });
  };

  document.querySelectorAll<HTMLElement>("[data-glossary-root]").forEach((root) => {
    root.querySelectorAll("input, select").forEach((ctrl) => {
      ctrl.addEventListener("input", () => applyGlossaryFilters(root));
      ctrl.addEventListener("change", () => applyGlossaryFilters(root));
    });
    applyGlossaryFilters(root);
  });

  // Reset filters button
  document.querySelectorAll<HTMLButtonElement>("[data-reset-filters]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const root = document.querySelector<HTMLElement>("[data-glossary-root]");
      if (!root) return;
      root.querySelectorAll<HTMLInputElement>("[data-filter-search]").forEach((i) => { i.value = ""; });
      root.querySelectorAll<HTMLSelectElement>("select").forEach((s) => { s.value = ""; s.dispatchEvent(new Event("change", { bubbles: true })); });
      root.querySelectorAll<HTMLButtonElement>(".filter-pill").forEach((p) => {
        const isAll = (p.dataset.filterValue ?? "") === "";
        p.classList.toggle("filter-pill-active", isAll);
      });
      root.querySelectorAll<HTMLElement>("[data-term-card]").forEach((c) => {
        c.removeAttribute("data-beginner-hidden");
        c.classList.remove("hidden");
      });
      const cb = root.querySelector<HTMLInputElement>("[data-beginner-path]");
      if (cb) cb.checked = false;
      applyGlossaryFilters(root);
    });
  });

  // Copy prompt feedback (from GlossaryGrid context)
  document.addEventListener("click", async (e) => {
    const copyBtn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-copy-prompt]");
    if (!copyBtn || !copyBtn.closest("[data-glossary-grid]")) return;
    // Handled in TermCard script; just track here too if needed
  });
</script>
