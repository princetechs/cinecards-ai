<div class="rounded-lg border border-ink/10 bg-bone p-4 shadow-soft">
  <div class="flex items-center justify-between gap-3 border-b border-ink/10 pb-4">
    <div>
      <p class="eyebrow text-clay">Shot sequence</p>
      <h3 class="mt-1 text-xl font-black text-ink">Prioritized plan</h3>
    </div>
    <div class="flex items-center gap-2">
      <button
        class="focus-ring hidden rounded-lg border border-ink/12 bg-paper px-3 py-1.5 text-xs font-bold text-ink/70 hover:bg-ink hover:text-bone"
        type="button"
        data-save-pack
      >Save as pack</button>
      <span class="rounded-full bg-paper px-3 py-1 text-xs font-bold text-ink/60" data-plan-type>Waiting</span>
    </div>
  </div>
  <div class="mt-4 space-y-3" data-plan-output>
    <div class="rounded-lg bg-paper p-5 text-sm leading-6 text-ink/62">
      Enter a topic to generate a compact coverage plan.
    </div>
  </div>
  <p class="mt-3 hidden text-xs font-bold text-clay" data-save-pack-status></p>
</div>

<script>
  type SavedPackItem = {
    termId: string;
    termName: string;
    prompt: string;
    durationSec: number;
  };
  type SavedPack = {
    id: string;
    name: string;
    topic: string;
    savedAt: string;
    items: SavedPackItem[];
  };

  const STORAGE_KEY = "cinecards.savedPacks";

  const slugify = (value: string) =>
    value.toLowerCase().trim().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "") || "pack";

  const readSaved = (): SavedPack[] => {
    if (typeof localStorage === "undefined") return [];
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return [];
      const parsed = JSON.parse(raw);
      return Array.isArray(parsed) ? parsed as SavedPack[] : [];
    } catch {
      return [];
    }
  };

  const writeSaved = (packs: SavedPack[]) => {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(packs));
    window.dispatchEvent(new CustomEvent("cinecards:saved-packs-updated"));
  };

  const collectCurrentPlan = (): { topic: string; items: SavedPackItem[] } | null => {
    const output = document.querySelector<HTMLElement>("[data-plan-output]");
    if (!output) return null;
    const cards = Array.from(output.querySelectorAll<HTMLElement>("article"));
    const items: SavedPackItem[] = cards.map((card) => {
      const termName = card.querySelector("h4")?.textContent?.trim() ?? "";
      const meta = card.querySelector("p")?.textContent?.trim() ?? "";
      const duration = meta.match(/(\d+)s/)?.[1];
      const durationSec = duration ? Number(duration) : 3;
      const prompt = card.querySelector<HTMLButtonElement>("[data-copy-prompt]")?.dataset.copyPrompt ?? "";
      const termId = slugify(termName);
      return { termId, termName, prompt, durationSec };
    }).filter((item) => item.termName && item.prompt);
    if (items.length === 0) return null;
    const topic = document.querySelector<HTMLTextAreaElement>("[data-planner-topic]")?.value.trim() || "";
    return { topic, items };
  };

  const updateButtonVisibility = () => {
    const button = document.querySelector<HTMLButtonElement>("[data-save-pack]");
    if (!button) return;
    const plan = collectCurrentPlan();
    if (plan && plan.items.length > 0) {
      button.classList.remove("hidden");
    } else {
      button.classList.add("hidden");
    }
  };

  document.addEventListener("click", (event) => {
    const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-save-pack]");
    if (!button) return;
    const plan = collectCurrentPlan();
    if (!plan) return;
    const defaultName = plan.topic ? plan.topic.slice(0, 60) : "My pack";
    const name = window.prompt("Name this pack", defaultName);
    if (!name || !name.trim()) return;

    const status = document.querySelector<HTMLElement>("[data-save-pack-status]");
    const saved = readSaved();
    const id = `${slugify(name)}-${Date.now().toString(36)}`;
    saved.unshift({
      id,
      name: name.trim(),
      topic: plan.topic,
      savedAt: new Date().toISOString(),
      items: plan.items
    });
    writeSaved(saved);

    if (status) {
      status.textContent = `Saved "${name.trim()}" to this device. View it on /packs.`;
      status.classList.remove("hidden");
      setTimeout(() => status.classList.add("hidden"), 3200);
    }
  });

  window.addEventListener("cinecards:plan-built", updateButtonVisibility);
  updateButtonVisibility();
</script>
