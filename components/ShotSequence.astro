<div class="rounded-lg border border-ink/10 bg-bone p-4 shadow-soft">
  <div class="flex items-center justify-between gap-3 border-b border-ink/10 pb-4">
    <div>
      <p class="eyebrow text-clay">Shot plan</p>
      <h3 class="mt-1 text-xl font-black text-ink">Your Shot Plan</h3>
      <p class="mt-1 text-xs font-semibold text-ink/48">Paste-ready prompts before you spend model credits.</p>
    </div>
    <div class="flex items-center gap-2">
      <label class="sr-only" for="model-export-select">Model export</label>
      <select
        id="model-export-select"
        class="focus-ring rounded-lg border border-ink/12 bg-white px-2 py-1.5 text-xs font-bold text-ink/70"
        data-model-export
      >
        <option value="generic">Generic</option>
        <option value="runway">Runway</option>
        <option value="pika">Pika</option>
        <option value="sora">Sora</option>
        <option value="kling-veo">Kling/Veo</option>
      </select>
      <button
        class="focus-ring hidden rounded-lg border border-ink/12 bg-paper px-3 py-1.5 text-xs font-bold text-ink/70 hover:bg-ink hover:text-bone"
        type="button"
        data-copy-all-prompts
      >Copy All</button>
      <button
        class="focus-ring hidden rounded-lg border border-ink/12 bg-paper px-3 py-1.5 text-xs font-bold text-ink/70 hover:bg-ink hover:text-bone"
        type="button"
        data-save-pack
      >Save as Recipe</button>
      <span class="rounded-full bg-paper px-3 py-1 text-xs font-bold text-ink/60" data-plan-type>Waiting</span>
    </div>
  </div>
  <div class="mt-4 space-y-3" data-plan-output>
    <div class="rounded-lg bg-paper p-5 text-sm leading-6 text-ink/62">
      Enter your idea above and tap Create My Shot Plan.
    </div>
  </div>
  <div class="mt-4 rounded-lg border border-clay/20 bg-clay/5 p-3 text-xs leading-5 text-ink/64" data-model-guidance>
    <strong class="text-ink">Where to paste:</strong> Use Generic for any tool. Pick Runway, Pika, Sora, or Kling/Veo to add model-specific direction before copying.
  </div>
  <div class="mt-4 grid gap-3 rounded-lg border border-ink/10 bg-paper p-4 sm:grid-cols-[1fr_auto] sm:items-center">
    <div>
      <p class="text-sm font-black text-ink">Want a client-ready version?</p>
      <p class="mt-1 text-xs leading-5 text-ink/58">Turn this rough plan into a polished shot list, prompt pack, and retry checklist.</p>
    </div>
    <a href="/services" class="focus-ring inline-flex h-10 items-center justify-center rounded-full bg-ink px-4 text-xs font-black text-bone no-underline hover:bg-clay">Request pack</a>
  </div>
  <p class="mt-3 hidden text-xs font-bold text-clay" data-save-pack-status></p>
</div>

<script>
  type SavedPackItem = {
    termId: string;
    termName: string;
    prompt: string;
    durationSec: number;
  };
  type SavedPack = {
    id: string;
    name: string;
    topic: string;
    savedAt: string;
    items: SavedPackItem[];
  };

  const STORAGE_KEY = "aiscreens.savedPacks";

  const slugify = (value: string) =>
    value.toLowerCase().trim().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "") || "pack";

  const readSaved = (): SavedPack[] => {
    if (typeof localStorage === "undefined") return [];
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return [];
      const parsed = JSON.parse(raw);
      return Array.isArray(parsed) ? parsed as SavedPack[] : [];
    } catch {
      return [];
    }
  };

  const writeSaved = (packs: SavedPack[]) => {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(packs));
    window.dispatchEvent(new CustomEvent("aiscreens:saved-packs-updated"));
  };

  const collectCurrentPlan = (): { topic: string; items: SavedPackItem[] } | null => {
    const output = document.querySelector<HTMLElement>("[data-plan-output]");
    if (!output) return null;
    const cards = Array.from(output.querySelectorAll<HTMLElement>("article"));
    const items: SavedPackItem[] = cards.map((card) => {
      const termName = card.querySelector("h4")?.textContent?.trim() ?? "";
      const meta = card.querySelector("p.text-xs")?.textContent?.trim() ?? "";
      const duration = meta.match(/(\d+)s/)?.[1];
      const durationSec = duration ? Number(duration) : 3;
      const prompt = card.querySelector<HTMLButtonElement>("[data-copy-prompt]")?.dataset.copyPrompt ?? "";
      const termId = slugify(termName);
      return { termId, termName, prompt, durationSec };
    }).filter((item) => item.termName && item.prompt);
    if (items.length === 0) return null;
    const topic = document.querySelector<HTMLTextAreaElement>("[data-planner-topic]")?.value.trim() || "";
    return { topic, items };
  };

  const updateButtonVisibility = () => {
    const plan = collectCurrentPlan();
    const hasItems = plan && plan.items.length > 0;
    document.querySelector<HTMLButtonElement>("[data-save-pack]")?.classList.toggle("hidden", !hasItems);
    document.querySelector<HTMLButtonElement>("[data-copy-all-prompts]")?.classList.toggle("hidden", !hasItems);
  };

  document.addEventListener("click", async (event) => {
    const btn = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-copy-all-prompts]");
    if (!btn) return;
    const plan = collectCurrentPlan();
    if (!plan) return;
    const text = plan.items.map((item, i) => `Shot ${i + 1} — ${item.termName}\n${item.prompt}`).join("\n\n");
    await navigator.clipboard.writeText(text);
    const orig = btn.textContent;
    btn.textContent = "Copied ✓";
    setTimeout(() => { btn.textContent = orig; }, 2000);
  });

  document.addEventListener("click", (event) => {
    const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-save-pack]");
    if (!button) return;
    const plan = collectCurrentPlan();
    if (!plan) return;
    const defaultName = plan.topic ? plan.topic.slice(0, 60) : "My pack";
    const name = window.prompt("Name this pack", defaultName);
    if (!name || !name.trim()) return;

    const status = document.querySelector<HTMLElement>("[data-save-pack-status]");
    const saved = readSaved();
    const id = `${slugify(name)}-${Date.now().toString(36)}`;
    saved.unshift({
      id,
      name: name.trim(),
      topic: plan.topic,
      savedAt: new Date().toISOString(),
      items: plan.items
    });
    writeSaved(saved);

    if (status) {
      status.textContent = `Saved "${name.trim()}" to this device. View it on /packs.`;
      status.classList.remove("hidden");
      setTimeout(() => status.classList.add("hidden"), 3200);
    }
  });

  window.addEventListener("aiscreens:plan-built", updateButtonVisibility);
  updateButtonVisibility();
</script>
