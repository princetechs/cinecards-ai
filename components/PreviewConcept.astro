---
import type { Term } from "../types/term";
import PreviewCard from "./PreviewCard.astro";

interface Props {
  terms: Term[];
}

const { terms } = Astro.props;
---

<section class="section-pad bg-bone" id="previews">
  <div class="container-pad">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-2xl">
        <p class="eyebrow text-clay">3s / 5s previews</p>
        <h2 class="mt-3 text-3xl font-black tracking-tight text-ink sm:text-4xl">Preview cards are prompt-first today, video-ready later.</h2>
      </div>
      <span class="rounded-full bg-paper px-4 py-2 text-sm font-bold text-ink/62">previewVideoUrl is ready in JSON</span>
    </div>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {terms.map((term) => (
        <article class="rounded-lg border border-ink/10 bg-white p-4 shadow-soft">
          <div class="mb-3 flex items-center justify-between gap-3">
            <h3 class="font-black text-ink">{term.name}</h3>
            <span class="rounded-full bg-paper px-3 py-1 text-xs font-bold text-ink/58">{term.category}</span>
          </div>
          <PreviewCard term={term} />
        </article>
      ))}
    </div>
  </div>
</section>
