---
import type { Term } from "../types/term";

interface Props {
  terms: Term[];
}

const { terms } = Astro.props;
const starterTerms = terms.slice(0, 24);
---

<section class="section-pad bg-paper" id="prompt-output">
  <div class="container-pad grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
    <div>
      <p class="eyebrow text-clay">AI prompt output</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-ink sm:text-4xl">Film language becomes reusable prompt structure.</h2>
      <p class="mt-4 max-w-xl text-base leading-7 text-ink/68">
        Templates stay short: shot type, subject, action, camera idea, light, and duration.
      </p>
    </div>
    <div class="rounded-lg border border-ink/10 bg-bone p-5 shadow-soft" data-prompt-builder>
      <div class="grid gap-3 sm:grid-cols-[1fr_1fr_120px]">
        <label>
          <span class="sr-only">Term</span>
          <select class="focus-ring w-full rounded-lg border border-ink/12 bg-white px-3 py-3 text-sm" data-prompt-term>
            {starterTerms.map((term) => <option value={term.id}>{term.name}</option>)}
          </select>
        </label>
        <label>
          <span class="sr-only">Subject</span>
          <input class="focus-ring w-full rounded-lg border border-ink/12 bg-white px-3 py-3 text-sm" data-prompt-topic value="coffee shop morning reel" />
        </label>
        <label>
          <span class="sr-only">Duration</span>
          <select class="focus-ring w-full rounded-lg border border-ink/12 bg-white px-3 py-3 text-sm" data-prompt-duration>
            <option value="3s">3s</option>
            <option value="5s" selected>5s</option>
          </select>
        </label>
      </div>
      <div class="mt-4 rounded-lg bg-ink p-4">
        <p class="break-words font-mono text-sm leading-6 text-bone" data-prompt-result></p>
      </div>
      <button class="focus-ring mt-4 rounded-lg bg-clay px-4 py-2 text-sm font-black text-bone" type="button" data-copy-built-prompt>Copy prompt</button>
    </div>
  </div>
</section>

<script>
  import { buildPrompt } from "../lib/promptBuilder";
  import { getTermById } from "../lib/termSearch";

  const root = document.querySelector<HTMLElement>("[data-prompt-builder]");
  const result = root?.querySelector<HTMLElement>("[data-prompt-result]");
  const termControl = root?.querySelector<HTMLSelectElement>("[data-prompt-term]");
  const topicControl = root?.querySelector<HTMLInputElement>("[data-prompt-topic]");
  const durationControl = root?.querySelector<HTMLSelectElement>("[data-prompt-duration]");
  const copyButton = root?.querySelector<HTMLButtonElement>("[data-copy-built-prompt]");

  const updatePrompt = () => {
    const term = getTermById(termControl?.value ?? "");
    const topic = topicControl?.value ?? "";
    const duration = (durationControl?.value ?? "5s") as "3s" | "5s";
    if (term && result) result.textContent = buildPrompt(term, topic, duration);
  };

  [termControl, topicControl, durationControl].forEach((control) => {
    control?.addEventListener("input", updatePrompt);
    control?.addEventListener("change", updatePrompt);
  });

  copyButton?.addEventListener("click", async () => {
    await navigator.clipboard.writeText(result?.textContent ?? "");
    window.dispatchEvent(new CustomEvent("cinecards:prompt-copied"));
    copyButton.textContent = "Copied";
    setTimeout(() => {
      copyButton.textContent = "Copy prompt";
    }, 1200);
  });

  updatePrompt();
</script>
