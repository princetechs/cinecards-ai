---
import type { Term } from "../types/term";

interface Props {
  term: Term;
}

const { term } = Astro.props;
---

<div
  class="rounded-lg border border-ink/10 bg-paper p-3"
  data-preview-scope
  data-preview-3={term.previewPrompt3s}
  data-preview-5={term.previewPrompt5s}
>
  <div class="relative film-frame grid aspect-video place-items-center overflow-hidden rounded-lg">
    <span class="relative z-10 rounded-full bg-bone/90 px-3 py-1 text-xs font-black text-ink">previewVideoUrl: null</span>
  </div>
  <div class="mt-3 flex items-center gap-2">
    <button class="focus-ring rounded-lg bg-ink px-3 py-1.5 text-xs font-bold text-bone" type="button" data-preview-option="3">3s</button>
    <button class="focus-ring rounded-lg border border-ink/12 px-3 py-1.5 text-xs font-bold text-ink/64" type="button" data-preview-option="5">5s</button>
  </div>
  <p class="mt-3 text-xs leading-5 text-ink/64" data-preview-prompt>{term.previewPrompt3s}</p>
</div>
