---
import type { Term } from "../types/term";

interface Props {
  term: Term;
}

const { term } = Astro.props;
const posterAsset = term.assets?.find((asset) => asset.type === "image" || asset.type === "thumbnail");
const posterUrl = posterAsset?.url.replace(/-detail(\.[a-z]+)$/i, "-card$1") ?? posterAsset?.url;
const previewVideoUrl = term.previewVideoUrl;
---

<div
  class="rounded-lg border border-ink/10 bg-paper p-3"
  data-preview-scope
  data-preview3={term.previewPrompt3s}
  data-preview5={term.previewPrompt5s}
>
  {
    previewVideoUrl ? (
      <video
        class="preview-video film-frame block aspect-video w-full overflow-hidden rounded-lg object-cover"
        src={previewVideoUrl}
        poster={posterUrl}
        controls
        muted
        playsinline
        preload="metadata"
        width="640"
        height="360"
        aria-label={`Preview video for ${term.name}`}
      >
        <track kind="captions" src="/captions/silent-preview.vtt" srclang="en" label="No dialogue" />
      </video>
    ) : (
      <div class="relative film-frame grid aspect-video place-items-center overflow-hidden rounded-lg">
        <span class="relative z-10 rounded-full bg-bone/90 px-3 py-1 text-xs font-black text-ink">Preview clip planned</span>
      </div>
    )
  }
  <div class="mt-3 flex items-center gap-2">
    <button class="focus-ring rounded-lg bg-ink px-3 py-1.5 text-xs font-bold text-bone" type="button" data-preview-option="3">3s</button>
    <button class="focus-ring rounded-lg border border-ink/12 px-3 py-1.5 text-xs font-bold text-ink/64" type="button" data-preview-option="5">5s</button>
  </div>
  <p class="mt-3 text-xs leading-5 text-ink/64 prompt-text" data-preview-prompt>{term.previewPrompt3s}</p>
</div>
