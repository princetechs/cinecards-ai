---
type MediaSlot = {
  video: string;
  poster: string;
  fallbackImage?: string;
  label: string;
};

interface Props {
  media: MediaSlot;
  className?: string;
  eager?: boolean;
}

const { media, className = "", eager = false } = Astro.props;
---

<figure class={`media-loop ${className}`.trim()} data-media-lazy={eager ? undefined : "true"}>
  <video
    class="media-loop-video"
    autoplay
    muted
    loop
    playsinline
    preload={eager ? "metadata" : "none"}
    poster={eager ? media.poster : undefined}
    data-poster={eager ? undefined : media.poster}
    aria-label={media.label}
  >
    <source src={eager ? media.video : undefined} data-src={eager ? undefined : media.video} type="video/mp4" />
    <track kind="captions" src="/captions/silent-preview.vtt" srclang="en" label="No dialogue" />
  </video>
  {media.fallbackImage && (
    <img
      class="media-loop-fallback"
      src={media.fallbackImage}
      alt=""
      loading={eager ? "eager" : "lazy"}
      decoding="async"
      width="960"
      height="540"
    />
  )}
</figure>

<script>
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  const loadMediaLoop = (figure: Element) => {
    if (reducedMotion.matches) return;
    const video = figure.querySelector("video");
    const source = figure.querySelector("source");
    if (!(video instanceof HTMLVideoElement) || !(source instanceof HTMLSourceElement)) return;

    if (!video.poster && video.dataset.poster) {
      video.poster = video.dataset.poster;
    }

    if (!source.src && source.dataset.src) {
      source.src = source.dataset.src;
      video.load();
    }

    video.play().catch(() => undefined);
    figure.removeAttribute("data-media-lazy");
  };

  const mediaLoops = document.querySelectorAll("[data-media-lazy='true']");

  if (!("IntersectionObserver" in window)) {
    mediaLoops.forEach(loadMediaLoop);
  } else {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        loadMediaLoop(entry.target);
        observer.unobserve(entry.target);
      });
    }, { rootMargin: "360px 0px", threshold: 0.01 });

    mediaLoops.forEach((figure) => observer.observe(figure));
  }
</script>

<style>
  .media-loop {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 0;
    overflow: hidden;
    border-radius: inherit;
    background: #0f0f13;
  }

  .media-loop-video,
  .media-loop-fallback {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #0f0f13;
  }

  .media-loop-fallback {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .media-loop-video {
      display: none;
    }

    .media-loop-fallback {
      display: block;
    }
  }
</style>
