---
import type { Term } from "../types/term";
import { getTermByName } from "../lib/termSearch";

interface Props {
  term: Term;
}

const { term } = Astro.props;
const searchText = [
  term.name,
  term.category,
  term.priorityGroup,
  term.difficulty,
  term.shortDefinition,
  term.whyItMatters,
  term.tags.join(" "),
  term.relatedTerms.join(" ")
].join(" ").toLowerCase();
---

<article
  class="term-card flex h-full flex-col"
  data-term-card
  data-category={term.category}
  data-priority={term.priorityGroup}
  data-difficulty={term.difficulty}
  data-search={searchText}
>
  <!-- Tags row -->
  <div class="flex flex-wrap items-center gap-1.5" style="font-family:var(--font-ui)">
    <span class="tag-category">{term.category}</span>
    <span class="tag-difficulty">{term.difficulty}</span>
    <span class="tag-priority">{term.priorityGroup}</span>
  </div>

  <!-- Term name -->
  <h3 class="term-name mt-4">
    <a href={`/glossary/${term.id}`} class="term-name-link">{term.name}</a>
  </h3>

  <!-- Short definition — always visible -->
  <p class="term-def mt-3">{term.shortDefinition}</p>

  <!-- AI Prompt block — always visible -->
  <div
    class="prompt-block mt-5"
    data-preview-scope
    data-preview3={term.previewPrompt3s}
    data-preview5={term.previewPrompt5s}
  >
    <div class="prompt-header">
      <span class="prompt-label">▶ AI Prompt</span>
      <button class="prompt-copy-btn" type="button" data-copy-prompt={term.aiPromptTemplate}>Copy</button>
    </div>
    <p class="prompt-text" data-preview-prompt>{term.aiPromptTemplate}</p>
    <div class="prompt-footer">
      <button class="duration-pill duration-active" type="button" data-preview-option="3">3s</button>
      <button class="duration-pill" type="button" data-preview-option="5">5s</button>
    </div>
  </div>

  <!-- Collapsible details -->
  <div class="details-section" data-details hidden>
    <!-- Why it matters -->
    <div class="detail-row">
      <p class="detail-label">💡 Why it matters</p>
      <p class="detail-text">{term.whyItMatters}</p>
    </div>
    <!-- Human shoot hint -->
    <div class="detail-row">
      <p class="detail-label">🎬 Try this</p>
      <p class="detail-text">{term.humanShootHint}</p>
    </div>
    <!-- Common mistakes -->
    {term.commonMistakes.length > 0 && (
      <div class="detail-row">
        <p class="detail-label">⚠ Common mistakes</p>
        <ul class="detail-list">
          {term.commonMistakes.map((m) => <li>{m}</li>)}
        </ul>
      </div>
    )}
    <!-- Related terms -->
    {term.relatedTerms.length > 0 && (
      <div class="detail-row">
        <p class="detail-label">⊕ Related</p>
        <div class="related-chips">
          {term.relatedTerms.map((related) => {
            const match = getTermByName(related);
            return match
              ? <a class="related-chip" href={`/glossary/${match.id}`}>{related}</a>
              : <span class="related-chip related-chip-plain">{related}</span>;
          })}
        </div>
      </div>
    )}
  </div>

  <!-- Spacer pushes actions to bottom -->
  <div class="mt-auto"></div>

  <!-- Try With My Idea -->
  <div class="try-idea-row" data-try-idea-row>
    <div class="try-idea-wrap">
      <input
        class="try-idea-input"
        type="text"
        placeholder="Your subject (e.g. coffee shop, sunset hike…)"
        data-try-idea-input
        aria-label="Enter your subject"
      />
      <a
        class="try-idea-btn"
        href={`/planner?term=${encodeURIComponent(term.id)}&topic=`}
        data-try-idea-link
      >Try →</a>
    </div>
  </div>

  <!-- Toggle + action row -->
  <div class="card-footer mt-4 flex items-center justify-between gap-2">
    <button class="show-more-btn" type="button" data-toggle-details aria-expanded="false">
      <span data-toggle-label>Show more</span>
      <svg data-toggle-chevron class="chevron" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="flex gap-2">
      <button class="action-btn" type="button" data-know-term={term.id}>I know this</button>
      <a class="action-btn" href="/learn">Practice</a>
    </div>
  </div>
</article>

<style>
  .term-card {
    background: #FFFFFF;
    border: 1px solid #E6DDD1;
    border-radius: 20px;
    box-shadow: 0 12px 32px rgba(23, 23, 23, 0.06);
    padding: 24px;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }
  .term-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 48px rgba(23, 23, 23, 0.10);
  }

  /* Tags */
  .tag-category {
    border-radius: 999px; padding: 3px 10px;
    font-size: 11px; font-weight: 700; font-family: var(--font-ui, Inter, sans-serif);
    background: #FFE0D2; color: #B83A1F;
  }
  .tag-difficulty {
    border-radius: 999px; padding: 3px 10px;
    font-size: 11px; font-weight: 600; font-family: var(--font-ui, Inter, sans-serif);
    background: #EFE8DC; color: #4F4A45;
  }
  .tag-priority {
    border-radius: 999px; padding: 3px 10px;
    font-size: 11px; font-weight: 500; font-family: var(--font-ui, Inter, sans-serif);
    background: transparent; color: #7A7268;
  }

  /* Term name */
  .term-name {
    font-family: "Space Grotesk", var(--font-display, sans-serif);
    font-size: 1.5rem; font-weight: 700; line-height: 1.15;
    letter-spacing: -0.01em; color: #171717; margin: 0;
  }
  .term-name-link { color: inherit; text-decoration: none; }
  .term-name-link:hover { color: #E4572E; }

  /* Definition */
  .term-def {
    font-family: var(--font-body, Inter, sans-serif);
    font-size: 1rem; line-height: 1.6; color: #4F4A45; margin: 0;
  }

  /* Prompt block */
  .prompt-block {
    background: #101014;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    padding: 16px;
  }
  .prompt-header {
    display: flex; align-items: center; justify-content: space-between; gap: 8px;
    margin-bottom: 10px;
  }
  .prompt-label {
    font-family: var(--font-ui, Inter, sans-serif);
    font-size: 10px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(122,114,104,0.8); margin: 0;
  }
  .prompt-copy-btn {
    font-family: var(--font-ui, Inter, sans-serif);
    font-size: 11px; font-weight: 600;
    background: rgba(255,255,255,0.10); color: rgba(255,255,255,0.8);
    border: none; border-radius: 999px; padding: 4px 12px; cursor: pointer;
    transition: background 150ms ease;
  }
  .prompt-copy-btn:hover { background: rgba(255,255,255,0.20); }
  .prompt-text {
    font-family: var(--font-mono, "JetBrains Mono", monospace);
    font-size: 12.5px; line-height: 1.55; color: rgba(255,255,255,0.88);
    margin: 0; word-break: break-word;
  }
  .prompt-footer {
    display: flex; gap: 6px; margin-top: 12px;
  }
  .duration-pill {
    font-family: var(--font-ui, Inter, sans-serif);
    font-size: 11px; font-weight: 600;
    border: 1px solid rgba(255,255,255,0.18);
    color: rgba(255,255,255,0.55);
    background: transparent; border-radius: 999px;
    padding: 3px 10px; cursor: pointer; transition: all 150ms ease;
  }
  .duration-pill:hover { border-color: rgba(255,255,255,0.4); color: rgba(255,255,255,0.8); }
  .duration-active {
    background: rgba(255,255,255,0.14); color: #fff;
    border-color: rgba(255,255,255,0.25);
  }

  /* Collapsible details */
  .details-section {
    display: flex; flex-direction: column; gap: 16px; margin-top: 20px;
    border-top: 1px solid #E6DDD1; padding-top: 18px;
  }
  .detail-row { display: flex; flex-direction: column; gap: 6px; }
  .detail-label {
    font-family: var(--font-ui, Inter, sans-serif);
    font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
    color: #7A7268; margin: 0;
  }
  .detail-text {
    font-family: var(--font-body, Inter, sans-serif);
    font-size: 14.5px; line-height: 1.6; color: #4F4A45; margin: 0;
  }
  .detail-list {
    font-family: var(--font-body, Inter, sans-serif);
    font-size: 14.5px; line-height: 1.6; color: #4F4A45;
    padding-left: 18px; margin: 0;
  }
  .related-chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .related-chip {
    font-family: var(--font-ui, Inter, sans-serif);
    font-size: 11px; font-weight: 500;
    border-radius: 999px; padding: 3px 10px;
    background: #EFE8DC; color: #4F4A45; text-decoration: none;
    transition: background 150ms, color 150ms;
  }
  .related-chip:hover { background: #171717; color: #F8F5EF; }
  .related-chip-plain { cursor: default; }
  .related-chip-plain:hover { background: #EFE8DC; color: #4F4A45; }

  /* Try With My Idea */
  .try-idea-row {
    margin-top: 16px;
  }
  .try-idea-wrap {
    display: flex;
    gap: 6px;
    align-items: center;
  }
  .try-idea-input {
    flex: 1;
    height: 36px;
    padding: 0 12px;
    font-family: var(--font-ui, Inter, sans-serif);
    font-size: 12.5px;
    color: #171717;
    background: #F8F5EF;
    border: 1.5px solid #E6DDD1;
    border-radius: 999px;
    outline: none;
    transition: border-color 150ms;
    min-width: 0;
  }
  .try-idea-input::placeholder { color: #7A7268; }
  .try-idea-input:focus { border-color: #E4572E; }
  .try-idea-btn {
    flex-shrink: 0;
    height: 36px;
    padding: 0 14px;
    font-family: var(--font-ui, Inter, sans-serif);
    font-size: 12.5px;
    font-weight: 700;
    background: #E4572E;
    color: #fff;
    border-radius: 999px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: background 150ms;
    white-space: nowrap;
  }
  .try-idea-btn:hover { background: #B83A1F; }

  /* Footer */
  .show-more-btn {
    font-family: var(--font-ui, Inter, sans-serif);
    font-size: 12px; font-weight: 600; color: #7A7268;
    background: none; border: none; cursor: pointer;
    display: inline-flex; align-items: center; gap: 4px;
    padding: 0; transition: color 150ms;
  }
  .show-more-btn:hover { color: #E4572E; }
  .chevron { transition: transform 200ms ease; }
  .chevron.open { transform: rotate(180deg); }
  .action-btn {
    font-family: var(--font-ui, Inter, sans-serif);
    font-size: 12px; font-weight: 600; color: #7A7268;
    background: none; border: 1px solid #E6DDD1;
    border-radius: 999px; padding: 5px 13px; cursor: pointer;
    text-decoration: none; display: inline-block;
    transition: all 150ms ease;
  }
  .action-btn:hover { background: #F8F5EF; color: #171717; border-color: #D8CFC3; }
</style>

<script>
  // Collapsible details toggle
  document.querySelectorAll<HTMLElement>('[data-toggle-details]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.term-card');
      if (!card) return;
      const details = card.querySelector<HTMLElement>('[data-details]');
      const label = btn.querySelector<HTMLElement>('[data-toggle-label]');
      const chevron = btn.querySelector<SVGElement>('[data-toggle-chevron]');
      if (!details) return;
      const isOpen = !details.hidden;
      details.hidden = isOpen;
      btn.setAttribute('aria-expanded', String(!isOpen));
      if (label) label.textContent = isOpen ? 'Show more' : 'Show less';
      if (chevron) chevron.classList.toggle('open', !isOpen);
    });
  });

  // Duration toggle (3s / 5s)
  document.addEventListener('click', (e) => {
    const pill = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-preview-option]');
    if (!pill) return;
    const scope = pill.closest<HTMLElement>('[data-preview-scope]');
    if (!scope) return;
    const dur = pill.dataset.previewOption;
    const prompt = dur === '5' ? scope.dataset.preview5 : scope.dataset.preview3;
    const target = scope.querySelector<HTMLElement>('[data-preview-prompt]');
    if (target && prompt) target.textContent = prompt;
    scope.querySelectorAll<HTMLButtonElement>('[data-preview-option]').forEach((p) => {
      p.classList.toggle('duration-active', p === pill);
    });
  });

  // "I know this"
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-know-term]');
    if (!btn) return;
    const id = btn.dataset.knowTerm;
    if (!id) return;
    try {
      const known: string[] = JSON.parse(localStorage.getItem('cinecards.knownTerms') ?? '[]');
      if (!known.includes(id)) { known.push(id); localStorage.setItem('cinecards.knownTerms', JSON.stringify(known)); }
      btn.textContent = '✓ Known';
      btn.style.color = '#2F855A';
      btn.style.borderColor = '#2F855A';
    } catch {}
  });

  // "Try With My Idea" — update planner link as user types
  document.querySelectorAll<HTMLElement>('[data-try-idea-row]').forEach((row) => {
    const input = row.querySelector<HTMLInputElement>('[data-try-idea-input]');
    const link = row.querySelector<HTMLAnchorElement>('[data-try-idea-link]');
    if (!input || !link) return;
    const base = link.href.split('&topic=')[0] + '&topic=';
    input.addEventListener('input', () => {
      link.href = base + encodeURIComponent(input.value);
    });
  });

  // Copy prompt with feedback
  document.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-copy-prompt]');
    if (!btn) return;
    try {
      await navigator.clipboard.writeText(btn.dataset.copyPrompt ?? '');
      const orig = btn.textContent;
      btn.textContent = 'Copied ✓';
      setTimeout(() => { btn.textContent = orig; }, 2000);
      // Analytics
      const card = btn.closest<HTMLElement>('[data-term-card]');
      const termId = card?.querySelector<HTMLAnchorElement>('a[href^="/glossary/"]')?.getAttribute('href')?.split('/').pop();
      window.dispatchEvent(new CustomEvent('cinecards:prompt-copied'));
      try { const { track } = await import('../lib/analytics'); track('term_prompt_copied', { termId, surface: 'card' }); } catch {}
    } catch {}
  });
</script>
