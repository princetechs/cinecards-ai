<div class="relative" data-creator-login>
  <button
    class="focus-ring rounded-full border border-ink/15 bg-bone/80 px-3 py-2 text-sm font-semibold text-ink shadow-sm backdrop-blur transition hover:bg-bone"
    type="button"
    data-login-toggle
  >
    Track
  </button>
  <div
    class="absolute right-0 top-12 z-50 hidden w-72 rounded-lg border border-ink/10 bg-bone p-4 text-sm text-ink shadow-lift"
    data-login-panel
  >
    <p class="eyebrow text-clay">Local profile</p>
    <p class="mt-2 text-ink/70">Save prompts and learning progress on this device.</p>
    <form class="mt-4 flex gap-2" data-login-form>
      <input
        class="focus-ring min-w-0 flex-1 rounded-lg border border-ink/15 bg-white px-3 py-2 text-sm"
        data-login-name
        name="name"
        placeholder="Creator name"
        autocomplete="name"
      />
      <button class="focus-ring rounded-lg bg-ink px-3 py-2 text-sm font-semibold text-bone" type="submit">Save</button>
    </form>
    <div class="mt-4 grid grid-cols-3 gap-2 text-center" data-login-stats>
      <div class="rounded-lg bg-paper p-2">
        <span class="block text-lg font-bold" data-stat="promptsCopied">0</span>
        <span class="text-[0.66rem] uppercase tracking-wide text-ink/55">Prompts</span>
      </div>
      <div class="rounded-lg bg-paper p-2">
        <span class="block text-lg font-bold" data-stat="plansBuilt">0</span>
        <span class="text-[0.66rem] uppercase tracking-wide text-ink/55">Plans</span>
      </div>
      <div class="rounded-lg bg-paper p-2">
        <span class="block text-lg font-bold" data-stat="groupsDone">0</span>
        <span class="text-[0.66rem] uppercase tracking-wide text-ink/55">Path</span>
      </div>
    </div>
    <button class="mt-3 text-xs font-semibold text-ink/55 hover:text-ink" type="button" data-login-reset>Reset local profile</button>
  </div>
</div>

<script>
  const profileKey = "aiscreens.profile";

  type Profile = {
    name: string;
    promptsCopied: number;
    plansBuilt: number;
    groupsDone: string[];
  };

  const defaultProfile = (): Profile => ({
    name: "",
    promptsCopied: 0,
    plansBuilt: 0,
    groupsDone: []
  });

  const readProfile = (): Profile => {
    try {
      return { ...defaultProfile(), ...JSON.parse(localStorage.getItem(profileKey) || "{}") };
    } catch {
      return defaultProfile();
    }
  };

  const writeProfile = (profile: Profile) => {
    localStorage.setItem(profileKey, JSON.stringify(profile));
    window.dispatchEvent(new CustomEvent("aiscreens:profile-updated"));
  };

  const updateStats = () => {
    const profile = readProfile();
    document.querySelectorAll<HTMLElement>("[data-creator-login]").forEach((root) => {
      const toggle = root.querySelector<HTMLElement>("[data-login-toggle]");
      if (toggle) toggle.textContent = profile.name ? profile.name : "Track";
      root.querySelectorAll<HTMLElement>("[data-stat]").forEach((stat) => {
        const key = stat.dataset.stat as keyof Profile;
        const value = key === "groupsDone" ? profile.groupsDone.length : profile[key];
        stat.textContent = String(value ?? 0);
      });
    });
  };

  document.querySelectorAll<HTMLElement>("[data-creator-login]").forEach((root) => {
    const toggle = root.querySelector<HTMLElement>("[data-login-toggle]");
    const panel = root.querySelector<HTMLElement>("[data-login-panel]");
    const form = root.querySelector<HTMLFormElement>("[data-login-form]");
    const input = root.querySelector<HTMLInputElement>("[data-login-name]");
    const reset = root.querySelector<HTMLButtonElement>("[data-login-reset]");

    toggle?.addEventListener("click", () => panel?.classList.toggle("hidden"));
    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      const profile = readProfile();
      profile.name = input?.value.trim() || "Creator";
      writeProfile(profile);
      if (panel) panel.classList.add("hidden");
    });
    reset?.addEventListener("click", () => {
      localStorage.removeItem(profileKey);
      updateStats();
    });
  });

  window.addEventListener("aiscreens:prompt-copied", () => {
    const profile = readProfile();
    profile.promptsCopied += 1;
    writeProfile(profile);
  });

  window.addEventListener("aiscreens:plan-built", () => {
    const profile = readProfile();
    profile.plansBuilt += 1;
    writeProfile(profile);
  });

  window.addEventListener("aiscreens:group-complete", ((event: CustomEvent<string>) => {
    const profile = readProfile();
    if (!profile.groupsDone.includes(event.detail)) profile.groupsDone.push(event.detail);
    writeProfile(profile);
  }) as EventListener);

  window.addEventListener("aiscreens:profile-updated", updateStats);
  updateStats();
</script>
