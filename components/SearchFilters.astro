---
interface Props {
  categories: string[];
  priorityGroups: string[];
  difficulties: string[];
}

const { categories, priorityGroups, difficulties } = Astro.props;
---

<div class="search-filters" data-search-filters>
  <!-- Search bar -->
  <div class="search-bar-wrap">
    <svg class="search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
      <circle cx="6.5" cy="6.5" r="4.5" stroke="#7A7268" stroke-width="1.5"/>
      <path d="M10.5 10.5L14 14" stroke="#7A7268" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    <input
      class="search-input"
      data-filter-search
      type="search"
      placeholder="Search shots, lighting, movement, AI workflow…"
      aria-label="Search terms"
    />
  </div>

  <!-- Category pills -->
  <div class="filter-row" role="group" aria-label="Filter by category">
    <button class="filter-pill filter-pill-active" type="button" data-filter-type="category" data-filter-value="">All</button>
    {categories.map((cat) => (
      <button class="filter-pill" type="button" data-filter-type="category" data-filter-value={cat}>{cat}</button>
    ))}
  </div>

  <!-- Difficulty pills -->
  <div class="filter-row" role="group" aria-label="Filter by difficulty">
    <button class="filter-pill filter-pill-active" type="button" data-filter-type="difficulty" data-filter-value="">All levels</button>
    {difficulties.map((d) => (
      <button class="filter-pill" type="button" data-filter-type="difficulty" data-filter-value={d}>{d}</button>
    ))}
    <!-- Beginner path toggle -->
    <label class="beginner-toggle" title="Show Foundation + Core Visual Grammar only">
      <input type="checkbox" data-beginner-path aria-label="Beginner path" />
      <span>Beginner Path</span>
    </label>
  </div>

  <!-- Hidden selects for GlossaryGrid JS compatibility -->
  <select class="sr-only" data-filter-category aria-hidden="true">
    <option value=""></option>
    {categories.map((c) => <option value={c}>{c}</option>)}
  </select>
  <select class="sr-only" data-filter-priority aria-hidden="true">
    <option value=""></option>
    {priorityGroups.map((g) => <option value={g}>{g}</option>)}
  </select>
  <select class="sr-only" data-filter-difficulty aria-hidden="true">
    <option value=""></option>
    {difficulties.map((d) => <option value={d}>{d}</option>)}
  </select>
</div>

<style>
  .search-filters {
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: sticky;
    top: 60px;
    z-index: 10;
    background: #F8F5EF;
    padding-bottom: 16px;
  }

  /* Search */
  .search-bar-wrap {
    position: relative;
  }
  .search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    flex-shrink: 0;
  }
  .search-input {
    width: 100%;
    height: 48px;
    padding: 0 20px 0 44px;
    font-family: var(--font-ui, Inter, sans-serif);
    font-size: 15px;
    color: #171717;
    background: #fff;
    border: 1.5px solid #E6DDD1;
    border-radius: 999px;
    outline: none;
    transition: border-color 180ms;
    box-sizing: border-box;
  }
  .search-input::placeholder { color: #7A7268; }
  .search-input:focus { border-color: #E4572E; }

  /* Filter rows */
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }
  .filter-pill {
    font-family: var(--font-ui, Inter, sans-serif);
    font-size: 12px;
    font-weight: 600;
    border-radius: 999px;
    padding: 5px 14px;
    border: 1.5px solid #E6DDD1;
    background: #fff;
    color: #4F4A45;
    cursor: pointer;
    transition: all 150ms ease;
    white-space: nowrap;
  }
  .filter-pill:hover { border-color: #E4572E; color: #E4572E; }
  .filter-pill-active {
    background: #E4572E;
    border-color: #E4572E;
    color: #fff;
  }
  .filter-pill-active:hover { background: #B83A1F; border-color: #B83A1F; color: #fff; }

  /* Beginner path toggle */
  .beginner-toggle {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-ui, Inter, sans-serif);
    font-size: 12px;
    font-weight: 600;
    color: #7A7268;
    cursor: pointer;
    padding: 5px 14px;
    border: 1.5px solid #E6DDD1;
    border-radius: 999px;
    background: #fff;
    transition: all 150ms;
  }
  .beginner-toggle:hover { border-color: #D8CFC3; color: #4F4A45; }
  .beginner-toggle input { accent-color: #E4572E; width: 13px; height: 13px; margin: 0; }

  /* Screen-reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  const BEGINNER_PRIORITIES = ['Foundation', 'Core Visual Grammar'];

  document.querySelectorAll<HTMLElement>('[data-search-filters]').forEach((root) => {
    const catSelect = root.querySelector<HTMLSelectElement>('[data-filter-category]');
    const priSelect = root.querySelector<HTMLSelectElement>('[data-filter-priority]');
    const difSelect = root.querySelector<HTMLSelectElement>('[data-filter-difficulty]');
    const searchInput = root.querySelector<HTMLInputElement>('[data-filter-search]');
    const beginnerCb = root.querySelector<HTMLInputElement>('[data-beginner-path]');

    function fireChange(el: HTMLSelectElement | HTMLInputElement | null) {
      el?.dispatchEvent(new Event('input', { bubbles: true }));
      el?.dispatchEvent(new Event('change', { bubbles: true }));
    }

    // Pill clicks → update hidden selects
    root.querySelectorAll<HTMLButtonElement>('[data-filter-pill]').forEach(() => {});
    root.querySelectorAll<HTMLButtonElement>('.filter-pill').forEach((pill) => {
      pill.addEventListener('click', () => {
        const type = pill.dataset.filterType as string;
        const value = pill.dataset.filterValue ?? '';

        // Deactivate siblings
        root.querySelectorAll<HTMLButtonElement>(`.filter-pill[data-filter-type="${type}"]`).forEach((p) => {
          p.classList.remove('filter-pill-active');
        });
        pill.classList.add('filter-pill-active');

        if (type === 'category' && catSelect) { catSelect.value = value; fireChange(catSelect); }
        if (type === 'difficulty' && difSelect) { difSelect.value = value; fireChange(difSelect); }
      });
    });

    // Beginner path → clamp priority to Foundation + Core Visual Grammar
    beginnerCb?.addEventListener('change', () => {
      if (beginnerCb.checked && priSelect) {
        // Will be handled by GlossaryGrid filter with custom attr
      }
      fireChange(searchInput);
    });

    // Override GlossaryGrid filter to also respect beginner-path
    const glossaryRoot = document.querySelector<HTMLElement>('[data-glossary-root]');
    if (glossaryRoot && beginnerCb) {
      const origInput = glossaryRoot.querySelectorAll('input, select');
      // Re-apply filter when beginner-path changes
      beginnerCb.addEventListener('change', () => {
        const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-term-card]'));
        if (beginnerCb.checked) {
          cards.forEach((card) => {
            const pri = card.dataset.priority ?? '';
            if (!BEGINNER_PRIORITIES.includes(pri)) {
              card.setAttribute('data-beginner-hidden', 'true');
              card.classList.add('hidden');
            } else {
              card.removeAttribute('data-beginner-hidden');
            }
          });
        } else {
          cards.forEach((card) => {
            card.removeAttribute('data-beginner-hidden');
            card.classList.remove('hidden');
          });
          // Re-run the normal filter
          fireChange(searchInput);
        }
        // Update count
        const visible = document.querySelectorAll('[data-term-card]:not(.hidden)').length;
        const countEl = document.querySelector<HTMLElement>('[data-filter-count]');
        if (countEl) countEl.textContent = `Showing ${visible} of ${cards.length} terms`;
        document.querySelector<HTMLElement>('[data-empty-state]')?.classList.toggle('hidden', visible !== 0);
      });
    }
  });
</script>
