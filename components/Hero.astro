---
import { hero, tokens } from "../src/site.config";
---

<section
  style={`
    background: ${tokens.bgHero};
    min-height: calc(100vh - 64px);
    display: flex;
    align-items: center;
  `}
>
  <div
    style="
      width: 100%;
      max-width: 1280px;
      margin-inline: auto;
      padding-inline: clamp(20px, 4vw, 64px);
      padding-block: clamp(48px, 6vw, 80px);
    "
  >
    <div class="hero-split">

      <!-- ── LEFT ── -->
      <div class="hero-left">

        <!-- H1 -->
        <h1
          style="
            font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
            font-size: clamp(40px, 5.5vw, 64px);
            font-weight: 700;
            line-height: 1.04;
            color: #FFFFFF;
            margin: 0 0 24px 0;
            letter-spacing: -0.03em;
          "
        >
          {hero.headline1} {hero.headline2}<br />
          <span style={`color: ${tokens.textFaint};`}>{hero.headline3}<br />{hero.headline4}</span>
        </h1>

        <!-- Subtitle -->
        <p
          class="font-ui"
          style="
            font-size: clamp(15px, 1.5vw, 17px);
            line-height: 1.7;
            color: rgba(255,255,255,0.5);
            max-width: 420px;
            margin: 0 0 40px 0;
          "
        >
          {hero.subtitle}
        </p>

        <!-- CTAs -->
        <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 28px;">
          <a
            href="/glossary"
            class="font-ui focus-ring"
            style="
              display: inline-flex;
              align-items: center;
              justify-content: center;
              background: #E4572E;
              color: #fff;
              font-size: 15px;
              font-weight: 700;
              padding: 0 32px;
              height: 52px;
              border-radius: 999px;
              text-decoration: none;
              transition: background 0.15s;
              white-space: nowrap;
            "
            onmouseover="this.style.background='#B83A1F'"
            onmouseout="this.style.background='#E4572E'"
          >{hero.cta1Label}</a>
          <a
            href={hero.cta2Href}
            class="font-ui focus-ring"
            style="
              display: inline-flex;
              align-items: center;
              justify-content: center;
              background: transparent;
              color: rgba(255,255,255,0.85);
              font-size: 15px;
              font-weight: 700;
              padding: 0 32px;
              height: 52px;
              border-radius: 999px;
              border: 1.5px solid rgba(255,255,255,0.2);
              text-decoration: none;
              transition: border-color 0.15s, background 0.15s;
              white-space: nowrap;
            "
            onmouseover="this.style.borderColor='rgba(255,255,255,0.5)'; this.style.background='rgba(255,255,255,0.06)'"
            onmouseout="this.style.borderColor='rgba(255,255,255,0.2)'; this.style.background='transparent'"
          >{hero.cta2Label}</a>
        </div>

        <!-- Social proof -->
        <p
          class="font-ui"
          style="
            font-size: 13px;
            color: rgba(255,255,255,0.25);
            margin: 0;
            letter-spacing: 0.01em;
          "
        >{hero.socialProof}</p>
      </div>

      <!-- ── RIGHT: Demo card ── -->
      <div class="hero-right">
        <div class="demo-frame">

          <!-- Term card (white) -->
          <div class="demo-card">
            <!-- Tags row -->
            <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 12px; flex-wrap: wrap;">
              <span
                class="font-ui"
                style="font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.45); letter-spacing: 0.1em; text-transform: uppercase;"
              >Shots / Beginner</span>
              <span style="flex: 1;"></span>
              <span
                class="font-ui"
                style="font-size: 10px; font-weight: 700; color: #fff; background: #E4572E; border-radius: 6px; padding: 2px 10px; letter-spacing: 0.04em;"
              >Foundation</span>
            </div>

            <!-- White card -->
            <div
              style="
                background: #FFFFFF;
                border-radius: 14px;
                padding: 20px;
                margin-bottom: 14px;
              "
            >
              <h3
                style="
                  font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
                  font-size: 26px;
                  font-weight: 700;
                  color: #171717;
                  margin: 0 0 8px 0;
                  letter-spacing: -0.01em;
                "
              >Close-Up</h3>
              <p
                class="font-ui"
                style="font-size: 14px; color: #4F4A45; line-height: 1.55; margin: 0 0 16px 0;"
              >Frames the face or an important detail to show emotion.</p>

              <!-- Prompt block -->
              <div style="background: #0F0F13; border-radius: 10px; padding: 14px 16px;">
                <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 8px;">
                  <span class="font-ui" style="font-size: 9px; font-weight: 600; color: rgba(255,255,255,0.35); letter-spacing: 0.12em; text-transform: uppercase;">AI Prompt →</span>
                </div>
                <p class="font-mono" style="font-size: 12px; line-height: 1.6; color: rgba(255,255,255,0.75); margin: 0;">
                  <span style="color: #E4572E; font-weight: 500;">extreme close-up</span> of [subject],<br />
                  shallow DOF, cinematic lighting,<br />
                  5 seconds
                </p>
              </div>
            </div>

            <!-- Shot sequence strip -->
            <div
              style="
                background: rgba(255,255,255,0.04);
                border: 1px solid rgba(255,255,255,0.07);
                border-radius: 12px;
                padding: 14px 16px;
              "
            >
              <span
                class="font-ui"
                style="font-size: 9px; font-weight: 600; color: rgba(255,255,255,0.3); letter-spacing: 0.14em; text-transform: uppercase; display: block; margin-bottom: 12px;"
              >Shot Sequence</span>
              <div style="display: flex; align-items: center; gap: 0;">
                {[
                  { label: "Wide",    active: false },
                  { label: "Medium",  active: false },
                  { label: "Close",   active: true  },
                  { label: "Detail",  active: false },
                  { label: "Wide",    active: false },
                ].map((step, i) => (
                  <div style="display: flex; align-items: center; flex: 1; min-width: 0;">
                    <div style="display: flex; flex-direction: column; align-items: center; gap: 5px; flex-shrink: 0;">
                      <div
                        class="font-ui"
                        style={`
                          width: 28px; height: 28px; border-radius: 50%;
                          background: ${step.active ? '#E4572E' : 'rgba(255,255,255,0.07)'};
                          color: ${step.active ? '#fff' : 'rgba(255,255,255,0.4)'};
                          font-size: 10px; font-weight: 700;
                          display: flex; align-items: center; justify-content: center;
                          border: ${step.active ? 'none' : '1px solid rgba(255,255,255,0.1)'};
                          flex-shrink: 0;
                        `}
                      >{i + 1}</div>
                      <span class="font-ui" style="font-size: 7.5px; color: rgba(255,255,255,0.28); text-align: center; max-width: 34px; line-height: 1.2;">{step.label}</span>
                    </div>
                    {i < 4 && (
                      <div style="flex: 1; height: 1px; background: rgba(255,255,255,0.07); margin: 0 3px 14px;"></div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .hero-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-right {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .demo-frame {
    background: #1A1A22;
    border-radius: 24px;
    padding: 24px;
    width: 100%;
    max-width: 400px;
    border: 1px solid rgba(255,255,255,0.07);
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.04),
      0 32px 80px rgba(0,0,0,0.6),
      0 8px 24px rgba(0,0,0,0.4);
    transform: rotate(-1deg);
  }

  .demo-card {
    /* inner content of the frame */
  }

  @media (max-width: 900px) {
    .hero-split {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .hero-right {
      order: -1;
    }
    .demo-frame {
      max-width: 360px;
      transform: none;
    }
  }

  @media (max-width: 480px) {
    .demo-frame {
      max-width: 100%;
    }
  }
</style>
