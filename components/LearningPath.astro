---
import type { Term } from "../types/term";

interface Props {
  terms: Term[];
}

const { terms } = Astro.props;

const groups = [
  {
    id: "Foundation",
    title: "Foundation",
    text: "Shot sizes, basic angles, camera movement, focus, composition, and one main light."
  },
  {
    id: "Core Visual Grammar",
    title: "Core Visual Grammar",
    text: "Coverage that makes action and dialogue clear: two shots, OTS, inserts, reactions, and motion."
  },
  {
    id: "Coverage and Edit Logic",
    title: "Coverage and Edit Logic",
    text: "Continuity, edit rhythm, B-roll, audio bridges, and lighting that keeps a sequence cuttable."
  },
  {
    id: "Advanced Look",
    title: "Advanced Look",
    text: "Lens language, exposure, color, motion effects, and lighting choices that create polish."
  },
  {
    id: "AI-Native Workflow",
    title: "AI-Native Workflow",
    text: "Reference images, prompt templates, consistency controls, provenance, and export thinking."
  }
];

const countByGroup = new Map<string, number>();
for (const term of terms) countByGroup.set(term.priorityGroup, (countByGroup.get(term.priorityGroup) ?? 0) + 1);
---

<section class="section-pad bg-paper" id="learn">
  <div class="container-pad">
    <div class="max-w-2xl">
      <p class="eyebrow text-clay">Learning path</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-ink sm:text-4xl">Progress from framing to prompt control.</h2>
    </div>
    <div class="mt-10 grid gap-3 md:grid-cols-5">
      {groups.map((group, index) => (
        <article class="rounded-lg border border-ink/10 bg-bone p-5 shadow-soft" data-group-card={group.id}>
          <span class="text-xs font-black uppercase tracking-wide text-clay">0{index + 1}</span>
          <h3 class="mt-3 text-lg font-black text-ink">{group.title}</h3>
          <p class="mt-3 text-sm leading-6 text-ink/68">{group.text}</p>
          <div class="mt-5 space-y-2">
            <div class="flex items-center justify-between gap-2 text-[0.7rem] font-bold uppercase tracking-wide text-ink/55">
              <span>Quiz progress</span>
              <span data-group-progress-label={group.id}>0 / 0</span>
            </div>
            <div class="h-1.5 w-full overflow-hidden rounded-full bg-paper">
              <div class="h-full bg-ink transition-all" data-group-progress-bar={group.id} style="width:0%"></div>
            </div>
          </div>
          <div class="mt-5 flex items-center justify-between gap-3">
            <span class="rounded-full bg-paper px-3 py-1 text-xs font-bold text-ink/62">{countByGroup.get(group.id) ?? 0} cards</span>
            <button class="focus-ring rounded-lg border border-ink/12 px-3 py-1.5 text-xs font-bold text-ink/70 hover:bg-ink hover:text-bone" type="button" data-complete-group={group.id}>
              Mark
            </button>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-complete-group]").forEach((button) => {
    button.addEventListener("click", () => {
      const group = button.dataset.completeGroup ?? "";
      window.dispatchEvent(new CustomEvent("cinecards:group-complete", { detail: group }));
      button.textContent = "Saved";
      button.classList.add("bg-ink", "text-bone");
    });
  });

  const QUIZ_SCORES_KEY = "cinecards.quizScores";

  type QuizGroupEntry = { correct: number; total: number };
  type QuizScoresShape = {
    nameTheTerm?: QuizGroupEntry;
    pickTheShot?: QuizGroupEntry;
    orderSequence?: QuizGroupEntry;
    byPriorityGroup?: Record<string, QuizGroupEntry>;
  };

  const renderQuizProgress = () => {
    let scores: QuizScoresShape = {};
    try {
      const raw = localStorage.getItem(QUIZ_SCORES_KEY);
      if (raw) scores = JSON.parse(raw);
    } catch {
      scores = {};
    }
    const byGroup = scores.byPriorityGroup ?? {};
    document.querySelectorAll<HTMLElement>("[data-group-progress-label]").forEach((el) => {
      const group = el.dataset.groupProgressLabel ?? "";
      const entry = byGroup[group] ?? { correct: 0, total: 0 };
      el.textContent = `${entry.correct} / ${entry.total}`;
    });
    document.querySelectorAll<HTMLElement>("[data-group-progress-bar]").forEach((el) => {
      const group = el.dataset.groupProgressBar ?? "";
      const entry = byGroup[group] ?? { correct: 0, total: 0 };
      const pct = entry.total ? Math.round((entry.correct / entry.total) * 100) : 0;
      el.style.width = `${pct}%`;
    });
  };

  window.addEventListener("cinecards:quiz-scores-updated", renderQuizProgress);
  renderQuizProgress();
</script>
