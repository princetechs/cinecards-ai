---
interface Props {
  type?: "tip" | "info" | "warning";
}
const { type = "tip" } = Astro.props;
const config = {
  tip:     { icon: "💡", label: "Tip",     bg: "rgba(228,87,46,0.08)",  border: "rgba(228,87,46,0.25)",  color: "#E4572E" },
  info:    { icon: "ℹ️",  label: "Note",    bg: "rgba(59,130,246,0.08)", border: "rgba(59,130,246,0.25)", color: "#60a5fa" },
  warning: { icon: "⚠️",  label: "Warning", bg: "rgba(234,179,8,0.08)",  border: "rgba(234,179,8,0.25)",  color: "#facc15" },
}[type];
---
<aside
  style={`background: ${config.bg}; border-left: 3px solid ${config.border}; border-radius: 0 10px 10px 0; padding: 14px 18px; margin: 24px 0; display: flex; gap: 12px; align-items: flex-start;`}
>
  <span style="font-size: 16px; flex-shrink: 0; margin-top: 1px;" aria-hidden="true">{config.icon}</span>
  <div>
    <span style={`font-family: "Inter", sans-serif; font-size: 11px; font-weight: 700; color: ${config.color}; letter-spacing: 0.08em; text-transform: uppercase; display: block; margin-bottom: 4px;`}>{config.label}</span>
    <div class="callout-body" style="font-family: 'Inter', sans-serif; font-size: 14px; line-height: 1.6; color: #4F4A45;">
      <slot />
    </div>
  </div>
</aside>
